{% comment %}
  Past Winners Final CTA Section
  Dark navy background with centered heading and CTA
  ADA compliant, responsive, matches header/footer navy
{% endcomment %}

{%- liquid
  assign bg_color = section.settings.bg_color | default: '#1e3a5f'
  assign heading_color = section.settings.heading_color | default: '#ffffff'
  assign btn_bg = section.settings.btn_bg | default: '#3099d3'
  assign btn_text = section.settings.btn_text | default: '#ffffff'
  assign btn_border = section.settings.btn_border | default: '#3099d3'
  assign btn_hover_bg = section.settings.btn_hover_bg | default: '#2780b3'
  assign btn_hover_text = section.settings.btn_hover_text | default: '#ffffff'
  assign btn_hover_border = section.settings.btn_hover_border | default: '#2780b3'
-%}

<style>
  .past-winners-cta-{{ section.id }} {
    background-color: {{ bg_color }};
  }
  .past-winners-cta-{{ section.id }} .acs-cta-btn {
    background-color: {{ btn_bg }};
    color: {{ btn_text }};
    border: 1px solid {{ btn_border }};
  }
  .past-winners-cta-{{ section.id }} .acs-cta-btn:hover {
    background-color: {{ btn_hover_bg }};
    color: {{ btn_hover_text }};
    border-color: {{ btn_hover_border }};
    transform: scale(1.05);
    box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1);
  }
  .past-winners-cta-{{ section.id }} .acs-cta-btn:focus {
    outline: none;
    box-shadow: 0 0 0 2px #fff, 0 0 0 4px {{ btn_bg }};
  }
</style>

<section class="past-winners-cta-{{ section.id }} tw-py-20 md:tw-py-28" role="region" aria-labelledby="past-winners-cta-heading">
  <div class="tw-container tw-mx-auto tw-px-4">
    <div class="tw-mx-auto tw-max-w-2xl tw-text-center">
      <h2 
        id="past-winners-cta-heading" 
        class="tw-mb-10 tw-text-3xl tw-font-bold lg:tw-text-4xl xl:tw-text-5xl"
        style="color: {{ heading_color }};"
      >
        {{ section.settings.heading | default: 'Ready to Earn Your Entries?' }}
      </h2>

      {% if section.settings.show_cta %}
        <a 
          href="{{ section.settings.cta_link | default: '/how-to-enter' }}"
          class="acs-cta-btn tw-inline-flex tw-items-center tw-justify-center tw-rounded-lg tw-px-6 tw-py-3 tw-text-base tw-font-semibold tw-shadow-lg tw-transition-all"
        >
          {{ section.settings.cta_text | default: 'See How to Enter' }}
          <svg class="tw-ml-2 tw-h-5 tw-w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
          </svg>
        </a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Past Winners CTA",
  "class": "past-winners-cta-section",
  "settings": [
    {
      "type": "header",
      "content": "Section Styling"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#1e3a5f",
      "info": "Matches the header/footer navy color"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "CTA Button Colors"
    },
    {
      "type": "color",
      "id": "btn_bg",
      "label": "Background",
      "default": "#3099d3"
    },
    {
      "type": "color",
      "id": "btn_text",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "btn_border",
      "label": "Border color",
      "default": "#3099d3"
    },
    {
      "type": "color",
      "id": "btn_hover_bg",
      "label": "Hover background",
      "default": "#2780b3"
    },
    {
      "type": "color",
      "id": "btn_hover_text",
      "label": "Hover text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "btn_hover_border",
      "label": "Hover border color",
      "default": "#2780b3"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Ready to Earn Your Entries?"
    },
    {
      "type": "header",
      "content": "CTA Button"
    },
    {
      "type": "checkbox",
      "id": "show_cta",
      "label": "Show CTA button",
      "default": true
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA button text",
      "default": "See How to Enter"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA button link"
    }
  ],
  "presets": [
    {
      "name": "Past Winners CTA",
      "category": "Call to Action"
    }
  ]
}
{% endschema %}