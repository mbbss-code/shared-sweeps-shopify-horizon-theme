{% comment %}
  Hero section with audience toggle (Brands/Customers)
  Two-column layout: content (left) + brand ad collage (right)
  SEO optimized, ADA compliant, responsive
{% endcomment %}

{%- liquid
  assign bg_gradient_start = section.settings.bg_gradient_start | default: '#0a1124'
  assign bg_gradient_end = section.settings.bg_gradient_end | default: '#24456e'
  assign heading_color = section.settings.heading_color | default: '#ffffff'
  assign description_color = section.settings.description_color | default: '#9fb3d1'
  assign primary_btn_bg = section.settings.primary_btn_bg | default: '#2f6fed'
  assign primary_btn_text = section.settings.primary_btn_text | default: '#ffffff'
  assign primary_btn_border = section.settings.primary_btn_border | default: '#2f6fed'
  assign primary_btn_hover_bg = section.settings.primary_btn_hover_bg | default: '#2456c0'
  assign primary_btn_hover_text = section.settings.primary_btn_hover_text | default: '#ffffff'
  assign primary_btn_hover_border = section.settings.primary_btn_hover_border | default: '#2456c0'
  assign secondary_btn_bg = section.settings.secondary_btn_bg | default: '#ffffff'
  assign secondary_btn_text = section.settings.secondary_btn_text | default: '#374151'
  assign secondary_btn_border = section.settings.secondary_btn_border | default: '#ffffff'
  assign secondary_btn_hover_bg = section.settings.secondary_btn_hover_bg | default: '#f1f5f9'
  assign secondary_btn_hover_text = section.settings.secondary_btn_hover_text | default: '#1f2937'
  assign secondary_btn_hover_border = section.settings.secondary_btn_hover_border | default: '#e2e8f0'
  assign toggle_active_bg = section.settings.toggle_active_bg | default: '#2f6fed'
  assign toggle_active_text = section.settings.toggle_active_text | default: '#ffffff'
  assign toggle_inactive_bg = section.settings.toggle_inactive_bg | default: '#16233d'
  assign toggle_inactive_text = section.settings.toggle_inactive_text | default: '#cbd5e1'
  assign toggle_container_bg = section.settings.toggle_container_bg | default: '#16233d'
  assign toggle_container_border = section.settings.toggle_container_border | default: '#2a3a57'
-%}

<style>
  .hero-section-{{ section.id }} {
    background: linear-gradient(180deg, {{ bg_gradient_start }} 0%, {{ bg_gradient_end }} 100%);
  }

  /* Toggle buttons */
  .hero-section-{{ section.id }} .acs-toggle-container {
    background-color: {{ toggle_container_bg }};
    border-color: {{ toggle_container_border }};
  }
  .hero-section-{{ section.id }} .acs-toggle-btn {
    background-color: {{ toggle_inactive_bg }};
    color: {{ toggle_inactive_text }};
  }
  .hero-section-{{ section.id }} .acs-toggle-btn[aria-pressed="true"] {
    background-color: {{ toggle_active_bg }};
    color: {{ toggle_active_text }};
  }

  /* Primary CTA */
  .hero-section-{{ section.id }} .acs-primary-btn {
    background-color: {{ primary_btn_bg }};
    color: {{ primary_btn_text }};
    border: 1px solid {{ primary_btn_border }};
  }
  .hero-section-{{ section.id }} .acs-primary-btn:hover {
    background-color: {{ primary_btn_hover_bg }};
    color: {{ primary_btn_hover_text }};
    border-color: {{ primary_btn_hover_border }};
    transform: scale(1.05);
    box-shadow: 0 20px 25px -5px rgba(0,0,0,0.25);
  }
  .hero-section-{{ section.id }} .acs-primary-btn:focus-visible {
    outline: none;
    box-shadow: 0 0 0 2px {{ primary_btn_bg }}, 0 0 0 4px #fff;
  }

  /* Secondary CTA */
  .hero-section-{{ section.id }} .acs-secondary-btn {
    background-color: {{ secondary_btn_bg }};
    color: {{ secondary_btn_text }};
    border: 2px solid {{ secondary_btn_border }};
  }
  .hero-section-{{ section.id }} .acs-secondary-btn:hover {
    background-color: {{ secondary_btn_hover_bg }};
    color: {{ secondary_btn_hover_text }};
    border-color: {{ secondary_btn_hover_border }};
  }
  .hero-section-{{ section.id }} .acs-secondary-btn:focus-visible {
    outline: none;
    box-shadow: 0 0 0 2px {{ secondary_btn_border }}, 0 0 0 4px #fff;
  }

  /* Brand ad collage */
  .hero-section-{{ section.id }} .acs-collage {
    position: relative;
    width: 100%;
    max-width: 28rem;
    height: 24rem;
    margin: 0 auto;
  }
  .hero-section-{{ section.id }} .acs-card {
    position: absolute;
    overflow: hidden;
    border-radius: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: #0f1b30;
    box-shadow: 0 20px 40px -12px rgba(0, 0, 0, 0.5);
  }
  .hero-section-{{ section.id }} .acs-card img,
  .hero-section-{{ section.id }} .acs-card .acs-card-ph {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
  }
  .hero-section-{{ section.id }} .acs-card .acs-card-ph svg {
    width: 100%;
    height: 100%;
  }
  .hero-section-{{ section.id }} .acs-card-1 { right: 2rem; top: 0; width: 13rem; transform: rotate(-6deg); }
  .hero-section-{{ section.id }} .acs-card-2 { right: 0; bottom: 1rem; width: 14rem; transform: rotate(3deg); z-index: 10; }
  .hero-section-{{ section.id }} .acs-card-3 {
    left: 50%; top: 50%; width: 15rem;
    transform: translate(-50%, -50%); z-index: 20;
    border: 2px solid rgba(255, 255, 255, 0.2);
    box-shadow: 0 25px 50px -12px rgba(47, 111, 237, 0.4);
  }
  @media (min-width: 640px) {
    .hero-section-{{ section.id }} .acs-collage { height: 28rem; }
    .hero-section-{{ section.id }} .acs-card-1 { width: 15rem; right: 3rem; }
    .hero-section-{{ section.id }} .acs-card-2 { width: 16rem; }
    .hero-section-{{ section.id }} .acs-card-3 { width: 18rem; }
  }
  .hero-section-{{ section.id }} .acs-glow {
    position: absolute; left: 0; top: 3rem;
    width: 6rem; height: 6rem; border-radius: 9999px;
    background: rgba(47, 111, 237, 0.2); filter: blur(40px); z-index: -10;
  }
</style>

{%- comment -%} JSON-LD Structured Data for Hero {%- endcomment -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": {{ section.settings.brands_heading | default: "A Better Way for Brands to Run Sweepstakes" | json }},
  "description": {{ section.settings.brands_description | default: "Shared Sweeps enables brands to give their customers entries into a $100,000 sweepstakes" | json }},
  "url": "{{ shop.url }}{{ page.url }}"
}
</script>

<section class="hero-section-{{ section.id }} tw-relative tw-overflow-hidden tw-px-4 tw-pb-20 tw-pt-16 md:tw-pb-28 md:tw-pt-24" role="region" aria-label="Hero section">
  <div class="tw-container tw-mx-auto">
    <div class="tw-grid tw-items-center tw-gap-12 lg:tw-grid-cols-2 lg:tw-gap-16">

      {%- comment -%} Left column: content {%- endcomment -%}
      <div class="tw-max-w-3xl tw-text-left">

        {%- comment -%} Audience Toggle {%- endcomment -%}
        {% if section.settings.show_toggle %}
          <div class="tw-mb-8 tw-flex tw-justify-start" role="group" aria-label="Select audience">
            <div class="acs-toggle-container tw-rounded-full tw-border tw-p-1" data-audience-toggle>
              <button
                type="button"
                class="acs-toggle-btn tw-rounded-full tw-px-6 tw-py-2 tw-text-sm tw-font-medium tw-transition-colors"
                data-audience="customers"
                aria-pressed="true"
              >
                {{ section.settings.toggle_customers_label | default: 'For Customers' }}
              </button>
              <button
                type="button"
                class="acs-toggle-btn tw-rounded-full tw-px-6 tw-py-2 tw-text-sm tw-font-medium tw-transition-colors"
                data-audience="brands"
                aria-pressed="false"
              >
                {{ section.settings.toggle_brands_label | default: 'For Brands' }}
              </button>
            </div>
          </div>
        {% endif %}

        {%- comment -%} Main Heading {%- endcomment -%}
        <h1 class="tw-mb-6 tw-text-4xl tw-font-bold tw-leading-tight lg:tw-text-5xl xl:tw-text-6xl" style="color: {{ heading_color }}">
          <span data-brands-content class="tw-hidden">{{ section.settings.brands_heading | default: 'A Better Way for Brands to Run Sweepstakes' }}</span>
          <span data-customers-content>{{ section.settings.customers_heading | default: 'Win $100,000 by purchasing from your favorite brands.' }}</span>
        </h1>

        {%- comment -%} Description {%- endcomment -%}
        <p class="tw-mb-10 tw-max-w-2xl tw-text-lg md:tw-text-xl" style="color: {{ description_color }};">
          <span data-brands-content class="tw-hidden">{{ section.settings.brands_description }}</span>
          <span data-customers-content>{{ section.settings.customers_description }}</span>
        </p>

        {%- comment -%} CTA Buttons {%- endcomment -%}
        <div class="tw-flex tw-flex-col tw-items-start tw-justify-start tw-gap-4 sm:tw-flex-row" role="group" aria-label="Call to action buttons">

          {%- comment -%} Brands Primary CTA {%- endcomment -%}
          {% if section.settings.brands_primary_cta_text != blank %}
            <span data-brands-content class="tw-hidden">
              {% if section.settings.brands_primary_cta_type == 'modal' %}
                <button
                  type="button"
                  class="acs-primary-btn tw-inline-flex tw-items-center tw-justify-center tw-rounded-lg tw-px-6 tw-py-3 tw-text-base tw-font-semibold tw-shadow-lg tw-transition-all"
                  data-contact-modal-trigger
                  aria-haspopup="dialog"
                >
                  {{ section.settings.brands_primary_cta_text }}
                  <svg class="tw-ml-2 tw-h-5 tw-w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
                  </svg>
                </button>
              {% else %}
                <a
                  href="{{ section.settings.brands_primary_cta_link }}"
                  class="acs-primary-btn tw-inline-flex tw-items-center tw-justify-center tw-rounded-lg tw-px-6 tw-py-3 tw-text-base tw-font-semibold tw-shadow-lg tw-transition-all"
                >
                  {{ section.settings.brands_primary_cta_text }}
                  <svg class="tw-ml-2 tw-h-5 tw-w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
                  </svg>
                </a>
              {% endif %}
            </span>
          {% endif %}

          {%- comment -%} Customers Primary CTA {%- endcomment -%}
          {% if section.settings.customers_primary_cta_text != blank %}
            <span data-customers-content>
              <a
                href="{{ section.settings.customers_primary_cta_link | default: '/how-to-enter' }}"
                class="acs-primary-btn tw-inline-flex tw-items-center tw-justify-center tw-rounded-lg tw-px-6 tw-py-3 tw-text-base tw-font-semibold tw-shadow-lg tw-transition-all"
              >
                {{ section.settings.customers_primary_cta_text }}
                <svg class="tw-ml-2 tw-h-5 tw-w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
                </svg>
              </a>
            </span>
          {% endif %}

          {%- comment -%} Brands Secondary CTA {%- endcomment -%}
          {% if section.settings.brands_secondary_cta_text != blank %}
            <span data-brands-content class="tw-hidden">
              <a
                href="{{ section.settings.brands_secondary_cta_link | default: '/how-it-works' }}"
                class="acs-secondary-btn tw-inline-flex tw-items-center tw-justify-center tw-rounded-lg tw-px-6 tw-py-3 tw-text-base tw-font-semibold tw-transition-all"
              >
                {{ section.settings.brands_secondary_cta_text }}
              </a>
            </span>
          {% endif %}

          {%- comment -%} Customers Secondary CTA {%- endcomment -%}
          {% if section.settings.customers_secondary_cta_text != blank %}
            <span data-customers-content>
              <a
                href="{{ section.settings.customers_secondary_cta_link | default: '/participating-brands' }}"
                class="acs-secondary-btn tw-inline-flex tw-items-center tw-justify-center tw-rounded-lg tw-px-6 tw-py-3 tw-text-base tw-font-semibold tw-transition-all"
              >
                {{ section.settings.customers_secondary_cta_text }}
              </a>
            </span>
          {% endif %}

        </div>

        {%- comment -%} Trust Indicators {%- endcomment -%}
        {% if section.settings.show_trust_indicators %}
          <div class="tw-mt-12 tw-flex tw-flex-wrap tw-items-center tw-justify-start tw-gap-4 lg:tw-gap-6 tw-text-sm tw-text-gray-300" role="list" aria-label="Trust indicators">
            <span data-brands-content class="tw-hidden tw-contents">
              {% for i in (1..3) %}
                {% assign indicator_text = 'brands_indicator_' | append: i %}
                {% if section.settings[indicator_text] != blank %}
                  <div class="tw-flex tw-items-center tw-gap-2" role="listitem">
                    <svg class="tw-h-4 tw-w-4 tw-text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    <span>{{ section.settings[indicator_text] }}</span>
                  </div>
                {% endif %}
              {% endfor %}
            </span>

            <span data-customers-content class="tw-contents">
              {% for i in (1..4) %}
                {% assign indicator_text = 'customers_indicator_' | append: i %}
                {% if section.settings[indicator_text] != blank %}
                  <div class="tw-flex tw-items-center tw-gap-2" role="listitem">
                    <svg class="tw-h-4 tw-w-4 tw-text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    <span>{{ section.settings[indicator_text] }}</span>
                  </div>
                {% endif %}
              {% endfor %}
            </span>
          </div>
        {% endif %}
      </div>

      {%- comment -%} Right column: brand ad collage {%- endcomment -%}
      {% if section.settings.show_collage %}
        <div class="acs-collage" aria-hidden="true">
          {% for i in (1..3) %}
            {% assign img_key = 'brand_ad_' | append: i %}
            {% assign alt_key = 'brand_ad_' | append: i | append: '_alt' %}
            {% assign img = section.settings[img_key] %}
            <div class="acs-card acs-card-{{ i }}">
              {% if img != blank %}
                <img
                  src="{{ img | image_url: width: 700 }}"
                  srcset="{{ img | image_url: width: 350 }} 350w, {{ img | image_url: width: 700 }} 700w, {{ img | image_url: width: 900 }} 900w"
                  sizes="(min-width: 1024px) 18rem, 60vw"
                  width="{{ img.width }}"
                  height="{{ img.height }}"
                  alt="{{ section.settings[alt_key] | default: img.alt | escape }}"
                  loading="lazy"
                >
              {% else %}
                <div class="acs-card-ph">{{ 'image' | placeholder_svg_tag }}</div>
              {% endif %}
            </div>
          {% endfor %}
          <div class="acs-glow"></div>
        </div>
      {% endif %}

    </div>
  </div>

  {%- comment -%} Background decoration {%- endcomment -%}
  <div class="tw-absolute -tw-top-40 tw-left-1/2 -tw-z-10 tw-h-96 tw-w-96 -tw-translate-x-1/2 tw-rounded-full tw-bg-blue-500/10 tw-blur-3xl" aria-hidden="true"></div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const section = document.querySelector('.hero-section-{{ section.id }}');
    if (!section) return;

    const toggleContainer = section.querySelector('[data-audience-toggle]');
    if (!toggleContainer) return;

    const buttons = toggleContainer.querySelectorAll('.acs-toggle-btn');

    function applyAudience(audience) {
      buttons.forEach(function(btn) {
        btn.setAttribute('aria-pressed', btn.dataset.audience === audience);
      });
      section.querySelectorAll('[data-brands-content]').forEach(function(el) {
        el.classList.toggle('tw-hidden', audience !== 'brands');
      });
      section.querySelectorAll('[data-customers-content]').forEach(function(el) {
        el.classList.toggle('tw-hidden', audience !== 'customers');
      });
    }

    function switchAudience(audience) {
      localStorage.setItem('sharedSweepsAudience', audience);
      applyAudience(audience);
      window.dispatchEvent(new Event('audienceChanged'));
    }

    buttons.forEach(function(btn) {
      btn.addEventListener('click', function() { switchAudience(btn.dataset.audience); });
    });

    window.addEventListener('audienceChanged', function() {
      applyAudience(localStorage.getItem('sharedSweepsAudience') || 'customers');
    });

    // Always pre-select "For Customers" on every page load
    switchAudience('customers');
  });
</script>

