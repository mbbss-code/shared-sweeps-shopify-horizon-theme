{% comment %}
  Hero section with audience toggle (Brands/Customers)
  SEO optimized, ADA compliant, responsive
{% endcomment %}

{%- liquid
  assign bg_color = section.settings.bg_color | default: '#ffffff'
  assign heading_color = section.settings.heading_color | default: '#000000'
  assign description_color = section.settings.description_color | default: '#4b5563'
  assign primary_btn_bg = section.settings.primary_btn_bg | default: '#9333ea'
  assign primary_btn_text = section.settings.primary_btn_text | default: '#ffffff'
  assign primary_btn_border = section.settings.primary_btn_border | default: '#9333ea'
  assign primary_btn_hover_bg = section.settings.primary_btn_hover_bg | default: '#7e22ce'
  assign primary_btn_hover_text = section.settings.primary_btn_hover_text | default: '#ffffff'
  assign primary_btn_hover_border = section.settings.primary_btn_hover_border | default: '#7e22ce'
  assign secondary_btn_bg = section.settings.secondary_btn_bg | default: '#ffffff'
  assign secondary_btn_text = section.settings.secondary_btn_text | default: '#374151'
  assign secondary_btn_border = section.settings.secondary_btn_border | default: '#d1d5db'
  assign secondary_btn_hover_bg = section.settings.secondary_btn_hover_bg | default: '#f9fafb'
  assign secondary_btn_hover_text = section.settings.secondary_btn_hover_text | default: '#374151'
  assign secondary_btn_hover_border = section.settings.secondary_btn_hover_border | default: '#9ca3af'
  assign toggle_active_bg = section.settings.toggle_active_bg | default: '#3099d3'
  assign toggle_active_text = section.settings.toggle_active_text | default: '#ffffff'
  assign toggle_inactive_bg = section.settings.toggle_inactive_bg | default: 'transparent'
  assign toggle_inactive_text = section.settings.toggle_inactive_text | default: '#374151'
  assign toggle_container_bg = section.settings.toggle_container_bg | default: '#f3f4f6'
  assign toggle_container_border = section.settings.toggle_container_border | default: '#e5e7eb'
-%}

<style>
  .hero-section-{{ section.id }} {
    background-color: {{ bg_color }};
  }

  /* Toggle buttons */
  .hero-section-{{ section.id }} .acs-toggle-container {
    background-color: {{ toggle_container_bg }};
    border-color: {{ toggle_container_border }};
  }
  .hero-section-{{ section.id }} .acs-toggle-btn {
    background-color: {{ toggle_inactive_bg }};
    color: {{ toggle_inactive_text }};
  }
  .hero-section-{{ section.id }} .acs-toggle-btn[aria-pressed="true"] {
    background-color: {{ toggle_active_bg }};
    color: {{ toggle_active_text }};
  }

  /* Primary CTA */
  .hero-section-{{ section.id }} .acs-primary-btn {
    background-color: {{ primary_btn_bg }};
    color: {{ primary_btn_text }};
    border: 1px solid {{ primary_btn_border }};
  }
  .hero-section-{{ section.id }} .acs-primary-btn:hover {
    background-color: {{ primary_btn_hover_bg }};
    color: {{ primary_btn_hover_text }};
    border-color: {{ primary_btn_hover_border }};
    transform: scale(1.05);
    box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1);
  }
  .hero-section-{{ section.id }} .acs-primary-btn:focus {
    outline: none;
    box-shadow: 0 0 0 2px {{ primary_btn_bg }}, 0 0 0 4px #fff;
  }

  /* Secondary CTA */
  .hero-section-{{ section.id }} .acs-secondary-btn {
    background-color: {{ secondary_btn_bg }};
    color: {{ secondary_btn_text }};
    border: 2px solid {{ secondary_btn_border }};
  }
  .hero-section-{{ section.id }} .acs-secondary-btn:hover {
    background-color: {{ secondary_btn_hover_bg }};
    color: {{ secondary_btn_hover_text }};
    border-color: {{ secondary_btn_hover_border }};
  }
  .hero-section-{{ section.id }} .acs-secondary-btn:focus {
    outline: none;
    box-shadow: 0 0 0 2px {{ secondary_btn_border }}, 0 0 0 4px #fff;
  }
</style>

{%- comment -%} JSON-LD Structured Data for Hero {%- endcomment -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": {{ section.settings.brands_heading | default: "A Better Way for Brands to Run Sweepstakes" | json }},
  "description": {{ section.settings.brands_description | default: "Shared Sweeps enables brands to give their customers entries into a $100,000 sweepstakes" | json }},
  "url": "{{ shop.url }}{{ page.url }}"
}
</script>

<section class="hero-section-{{ section.id }} tw-relative tw-overflow-hidden tw-px-4 tw-pb-20 tw-pt-16 md:tw-pb-28 md:tw-pt-24" role="region" aria-label="Hero section">
  <div class="tw-container tw-mx-auto">
    <div class="tw-mx-auto tw-max-w-3xl tw-text-center">
      
      {%- comment -%} Audience Toggle {%- endcomment -%}
      {% if section.settings.show_toggle %}
        <div class="tw-mb-8 tw-flex tw-justify-center" role="group" aria-label="Select audience">
          <div class="acs-toggle-container tw-rounded-full tw-border tw-p-1" data-audience-toggle>
            <button 
              type="button"
              class="acs-toggle-btn tw-rounded-full tw-px-6 tw-py-2 tw-text-sm tw-font-medium tw-transition-colors"
              data-audience="customers"
              aria-pressed="false"
            >
              {{ section.settings.toggle_customers_label | default: 'For Customers' }}
            </button>
            <button 
              type="button"
              class="acs-toggle-btn tw-rounded-full tw-px-6 tw-py-2 tw-text-sm tw-font-medium tw-transition-colors"
              data-audience="brands"
              aria-pressed="true"
            >
              {{ section.settings.toggle_brands_label | default: 'For Brands' }}
            </button>
          </div>
        </div>
      {% endif %}
      
      {%- comment -%} Main Heading {%- endcomment -%}
      <h1 class="tw-mb-6 tw-text-4xl tw-font-bold tw-leading-tight lg:tw-text-5xl xl:tw-text-6xl" style="color: {{ heading_color }}">
        <span data-brands-content>{{ section.settings.brands_heading | default: 'A Better Way for Brands to Run Sweepstakes' }}</span>
        <span data-customers-content class="tw-hidden">{{ section.settings.customers_heading | default: 'Win $100,000 by purchasing from your favorite brands.' }}</span>
      </h1>
      
      {%- comment -%} Description {%- endcomment -%}
      <p class="tw-mx-auto tw-mb-10 tw-max-w-2xl tw-text-lg md:tw-text-xl" style="color: {{ description_color }};">
        <span data-brands-content>{{ section.settings.brands_description }}</span>
        <span data-customers-content class="tw-hidden">{{ section.settings.customers_description }}</span>
      </p>

      {%- comment -%} CTA Buttons {%- endcomment -%}
      <div class="tw-flex tw-flex-col tw-items-center tw-justify-center tw-gap-4 sm:tw-flex-row" role="group" aria-label="Call to action buttons">
        {%- comment -%} Primary CTA {%- endcomment -%}
        <span data-brands-content>
          {% if section.settings.brands_primary_cta_type == 'modal' %}
            <button 
              type="button"
              class="acs-primary-btn tw-inline-flex tw-items-center tw-justify-center tw-rounded-lg tw-px-6 tw-py-3 tw-text-base tw-font-semibold tw-shadow-lg tw-transition-all"
              data-contact-modal-trigger
              aria-haspopup="dialog"
            >
              {{ section.settings.brands_primary_cta_text | default: 'Talk to Our Team' }}
              <svg class="tw-ml-2 tw-h-5 tw-w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
              </svg>
            </button>
          {% else %}
            <a 
              href="{{ section.settings.brands_primary_cta_link }}"
              class="acs-primary-btn tw-inline-flex tw-items-center tw-justify-center tw-rounded-lg tw-px-6 tw-py-3 tw-text-base tw-font-semibold tw-shadow-lg tw-transition-all"
            >
              {{ section.settings.brands_primary_cta_text | default: 'Talk to Our Team' }}
              <svg class="tw-ml-2 tw-h-5 tw-w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
              </svg>
            </a>
          {% endif %}
        </span>
        
        <span data-customers-content class="tw-hidden">
          <a 
            href="{{ section.settings.customers_primary_cta_link | default: '/how-to-enter' }}"
            class="acs-primary-btn tw-inline-flex tw-items-center tw-justify-center tw-rounded-lg tw-px-6 tw-py-3 tw-text-base tw-font-semibold tw-shadow-lg tw-transition-all"
          >
            {{ section.settings.customers_primary_cta_text | default: 'See How to Enter' }}
            <svg class="tw-ml-2 tw-h-5 tw-w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
            </svg>
          </a>
        </span>

        {%- comment -%} Secondary CTA {%- endcomment -%}
        <span data-brands-content>
          <a 
            href="{{ section.settings.brands_secondary_cta_link | default: '/how-it-works' }}"
            class="acs-secondary-btn tw-inline-flex tw-items-center tw-justify-center tw-rounded-lg tw-px-6 tw-py-3 tw-text-base tw-font-semibold tw-transition-all"
          >
            {{ section.settings.brands_secondary_cta_text | default: 'See How It Works' }}
          </a>
        </span>
        
        <span data-customers-content class="tw-hidden">
          <a 
            href="{{ section.settings.customers_secondary_cta_link | default: '/participating-brands' }}"
            class="acs-secondary-btn tw-inline-flex tw-items-center tw-justify-center tw-rounded-lg tw-px-6 tw-py-3 tw-text-base tw-font-semibold tw-transition-all"
          >
            {{ section.settings.customers_secondary_cta_text | default: 'View Participating Brands' }}
          </a>
        </span>
      </div>

      {%- comment -%} Trust Indicators {%- endcomment -%}
      {% if section.settings.show_trust_indicators %}
        <div class="tw-mt-12 tw-flex tw-flex-wrap tw-items-center tw-justify-center tw-gap-4 lg:tw-gap-6 tw-text-sm tw-text-gray-600" role="list" aria-label="Trust indicators">
          <span data-brands-content class="tw-contents">
            {% for i in (1..3) %}
              {% assign indicator_text = 'brands_indicator_' | append: i %}
              {% if section.settings[indicator_text] != blank %}
                <div class="tw-flex tw-items-center tw-gap-2" role="listitem">
                  <svg class="tw-h-4 tw-w-4 tw-text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                  <span>{{ section.settings[indicator_text] }}</span>
                </div>
              {% endif %}
            {% endfor %}
          </span>
          
          <span data-customers-content class="tw-hidden tw-contents">
            {% for i in (1..4) %}
              {% assign indicator_text = 'customers_indicator_' | append: i %}
              {% if section.settings[indicator_text] != blank %}
                <div class="tw-flex tw-items-center tw-gap-2" role="listitem">
                  <svg class="tw-h-4 tw-w-4 tw-text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                  <span>{{ section.settings[indicator_text] }}</span>
                </div>
              {% endif %}
            {% endfor %}
          </span>
        </div>
      {% endif %}
    </div>
  </div>

  {%- comment -%} Background decoration {%- endcomment -%}
  <div class="tw-absolute -tw-top-40 tw-left-1/2 -tw-z-10 tw-h-96 tw-w-96 -tw-translate-x-1/2 tw-rounded-full tw-bg-purple-500/5 tw-blur-3xl" aria-hidden="true"></div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const section = document.querySelector('.hero-section-{{ section.id }}');
    if (!section) return;

    const toggleContainer = section.querySelector('[data-audience-toggle]');
    if (!toggleContainer) return;

    const buttons = toggleContainer.querySelectorAll('.acs-toggle-btn');
    const brandsContent = section.querySelectorAll('[data-brands-content]');
    const customersContent = section.querySelectorAll('[data-customers-content]');

    function switchAudience(audience) {
      buttons.forEach(btn => {
        btn.setAttribute('aria-pressed', btn.dataset.audience === audience);
      });

      if (audience === 'brands') {
        brandsContent.forEach(el => el.classList.remove('tw-hidden'));
        customersContent.forEach(el => el.classList.add('tw-hidden'));
      } else {
        brandsContent.forEach(el => el.classList.add('tw-hidden'));
        customersContent.forEach(el => el.classList.remove('tw-hidden'));
      }

      localStorage.setItem('sharedSweepsAudience', audience);
    }

    buttons.forEach(btn => {
      btn.addEventListener('click', () => switchAudience(btn.dataset.audience));
    });

    const savedAudience = localStorage.getItem('sharedSweepsAudience');
    if (savedAudience && savedAudience !== 'brands') {
      switchAudience(savedAudience);
    }
  });
</script>

