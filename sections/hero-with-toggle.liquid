{% comment %}
  Hero section with audience toggle (Brands/Customers)
  SEO optimized, ADA compliant, responsive
{% endcomment %}

{%- liquid
  assign bg_color = section.settings.bg_color | default: '#ffffff'
  assign heading_color = section.settings.heading_color | default: '#000000'
-%}

<style>
  .hero-section-{{ section.id }} {
    background-color: {{ bg_color }};
  }
</style>

{%- comment -%} JSON-LD Structured Data for Hero {%- endcomment -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": {{ section.settings.brands_heading | default: "A Better Way for Brands to Run Sweepstakes" | json }},
  "description": {{ section.settings.brands_description | default: "Shared Sweeps enables brands to give their customers entries into a $100,000 sweepstakes" | json }},
  "url": "{{ shop.url }}{{ page.url }}"
}
</script>

<section class="hero-section-{{ section.id }} tw-relative tw-overflow-hidden tw-px-4 tw-pb-20 tw-pt-16 md:tw-pb-28 md:tw-pt-24" role="region" aria-label="Hero section">
  <div class="tw-container tw-mx-auto">
    <div class="tw-mx-auto tw-max-w-3xl tw-text-center">
      
      {%- comment -%} Audience Toggle {%- endcomment -%}
      {% if section.settings.show_toggle %}
        <div class="tw-mb-8 tw-flex tw-justify-center" role="group" aria-label="Select audience">
          <div class="tw-rounded-full tw-border tw-border-gray-200 tw-bg-gray-100 tw-p-1" data-audience-toggle>
            <button 
              type="button"
              class="tw-rounded-full tw-px-6 tw-py-2 tw-text-sm tw-font-medium tw-transition-colors"
              data-audience="customers"
              aria-pressed="false"
            >
              {{ section.settings.toggle_customers_label | default: 'For Customers' }}
            </button>
            <button 
              type="button"
              class="tw-rounded-full tw-px-6 tw-py-2 tw-text-sm tw-font-medium tw-transition-colors tw-bg-primary tw-text-white"
              data-audience="brands"
              aria-pressed="true"
            >
              {{ section.settings.toggle_brands_label | default: 'For Brands' }}
            </button>
          </div>
        </div>
      {% endif %}
      
      {%- comment -%} Main Heading {%- endcomment -%}
      <h1 class="tw-mb-6 tw-text-4xl tw-font-bold tw-leading-tight lg:tw-text-5xl xl:tw-text-6xl" style="color: {{ heading_color }}">
        <span data-brands-content>{{ section.settings.brands_heading | default: 'A Better Way for Brands to Run Sweepstakes' }}</span>
        <span data-customers-content class="tw-hidden">{{ section.settings.customers_heading | default: 'Win $100,000 by purchasing from your favorite brands.' }}</span>
      </h1>
      
      {%- comment -%} Description {%- endcomment -%}
      <p class="tw-mx-auto tw-mb-10 tw-max-w-2xl tw-text-lg tw-text-gray-600 md:tw-text-xl">
        <span data-brands-content>{{ section.settings.brands_description }}</span>
        <span data-customers-content class="tw-hidden">{{ section.settings.customers_description }}</span>
      </p>

      {%- comment -%} CTA Buttons {%- endcomment -%}
      <div class="tw-flex tw-flex-col tw-items-center tw-justify-center tw-gap-4 sm:tw-flex-row" role="group" aria-label="Call to action buttons">
        {%- comment -%} Primary CTA {%- endcomment -%}
        <span data-brands-content>
          {% if section.settings.brands_primary_cta_type == 'modal' %}
            <button 
              type="button"
              class="tw-inline-flex tw-items-center tw-justify-center tw-rounded-lg tw-bg-gradient-to-r tw-from-purple-600 tw-to-pink-600 tw-px-6 tw-py-3 tw-text-base tw-font-semibold tw-text-white tw-shadow-lg tw-transition-all hover:tw-shadow-xl hover:tw-scale-105 focus:tw-outline-none focus:tw-ring-2 focus:tw-ring-purple-500 focus:tw-ring-offset-2"
              data-contact-modal-trigger
              aria-haspopup="dialog"
            >
              {{ section.settings.brands_primary_cta_text | default: 'Talk to Our Team' }}
              <svg class="tw-ml-2 tw-h-5 tw-w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
              </svg>
            </button>
          {% else %}
            <a 
              href="{{ section.settings.brands_primary_cta_link }}"
              class="tw-inline-flex tw-items-center tw-justify-center tw-rounded-lg tw-bg-gradient-to-r tw-from-purple-600 tw-to-pink-600 tw-px-6 tw-py-3 tw-text-base tw-font-semibold tw-text-white tw-shadow-lg tw-transition-all hover:tw-shadow-xl hover:tw-scale-105 focus:tw-outline-none focus:tw-ring-2 focus:tw-ring-purple-500 focus:tw-ring-offset-2"
            >
              {{ section.settings.brands_primary_cta_text | default: 'Talk to Our Team' }}
              <svg class="tw-ml-2 tw-h-5 tw-w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
              </svg>
            </a>
          {% endif %}
        </span>
        
        <span data-customers-content class="tw-hidden">
          <a 
            href="{{ section.settings.customers_primary_cta_link | default: '/how-to-enter' }}"
            class="tw-inline-flex tw-items-center tw-justify-center tw-rounded-lg tw-bg-gradient-to-r tw-from-purple-600 tw-to-pink-600 tw-px-6 tw-py-3 tw-text-base tw-font-semibold tw-text-white tw-shadow-lg tw-transition-all hover:tw-shadow-xl hover:tw-scale-105 focus:tw-outline-none focus:tw-ring-2 focus:tw-ring-purple-500 focus:tw-ring-offset-2"
          >
            {{ section.settings.customers_primary_cta_text | default: 'See How to Enter' }}
            <svg class="tw-ml-2 tw-h-5 tw-w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
            </svg>
          </a>
        </span>

        {%- comment -%} Secondary CTA {%- endcomment -%}
        <span data-brands-content>
          <a 
            href="{{ section.settings.brands_secondary_cta_link | default: '/how-it-works' }}"
            class="tw-inline-flex tw-items-center tw-justify-center tw-rounded-lg tw-border-2 tw-border-gray-300 tw-bg-white tw-px-6 tw-py-3 tw-text-base tw-font-semibold tw-text-gray-700 tw-transition-all hover:tw-border-gray-400 hover:tw-bg-gray-50 focus:tw-outline-none focus:tw-ring-2 focus:tw-ring-gray-500 focus:tw-ring-offset-2"
          >
            {{ section.settings.brands_secondary_cta_text | default: 'See How It Works' }}
          </a>
        </span>
        
        <span data-customers-content class="tw-hidden">
          <a 
            href="{{ section.settings.customers_secondary_cta_link | default: '/participating-brands' }}"
            class="tw-inline-flex tw-items-center tw-justify-center tw-rounded-lg tw-border-2 tw-border-gray-300 tw-bg-white tw-px-6 tw-py-3 tw-text-base tw-font-semibold tw-text-gray-700 tw-transition-all hover:tw-border-gray-400 hover:tw-bg-gray-50 focus:tw-outline-none focus:tw-ring-2 focus:tw-ring-gray-500 focus:tw-ring-offset-2"
          >
            {{ section.settings.customers_secondary_cta_text | default: 'View Participating Brands' }}
          </a>
        </span>
      </div>

      {%- comment -%} Trust Indicators {%- endcomment -%}
      {% if section.settings.show_trust_indicators %}
        <div class="tw-mt-12 tw-flex tw-flex-wrap tw-items-center tw-justify-center tw-gap-4 lg:tw-gap-6 tw-text-sm tw-text-gray-600" role="list" aria-label="Trust indicators">
          <span data-brands-content class="tw-contents">
            {% for i in (1..3) %}
              {% assign indicator_text = 'brands_indicator_' | append: i %}
              {% if section.settings[indicator_text] != blank %}
                <div class="tw-flex tw-items-center tw-gap-2" role="listitem">
                  <svg class="tw-h-4 tw-w-4 tw-text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                  <span>{{ section.settings[indicator_text] }}</span>
                </div>
              {% endif %}
            {% endfor %}
          </span>
          
          <span data-customers-content class="tw-hidden tw-contents">
            {% for i in (1..4) %}
              {% assign indicator_text = 'customers_indicator_' | append: i %}
              {% if section.settings[indicator_text] != blank %}
                <div class="tw-flex tw-items-center tw-gap-2" role="listitem">
                  <svg class="tw-h-4 tw-w-4 tw-text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                  <span>{{ section.settings[indicator_text] }}</span>
                </div>
              {% endif %}
            {% endfor %}
          </span>
        </div>
      {% endif %}
    </div>
  </div>

  {%- comment -%} Background decoration {%- endcomment -%}
  <div class="tw-absolute -tw-top-40 tw-left-1/2 -tw-z-10 tw-h-96 tw-w-96 -tw-translate-x-1/2 tw-rounded-full tw-bg-purple-500/5 tw-blur-3xl" aria-hidden="true"></div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const toggleContainer = document.querySelector('[data-audience-toggle]');
    if (!toggleContainer) return;

    const buttons = toggleContainer.querySelectorAll('button');
    const brandsContent = document.querySelectorAll('[data-brands-content]');
    const customersContent = document.querySelectorAll('[data-customers-content]');

    function switchAudience(audience) {
      // Update button states
      buttons.forEach(btn => {
        const isActive = btn.dataset.audience === audience;
        btn.setAttribute('aria-pressed', isActive);
        
        if (isActive) {
          btn.classList.add('tw-bg-primary', 'tw-text-white');
          btn.classList.add('tw-bg-[#3099d3]');
          btn.classList.remove('tw-bg-transparent', 'tw-text-gray-700');
        } else {
          btn.classList.remove('tw-bg-primary', 'tw-text-white');
          btn.classList.add('tw-bg-transparent', 'tw-text-gray-700');
        }
      });

      // Toggle content visibility
      if (audience === 'brands') {
        brandsContent.forEach(el => el.classList.remove('tw-hidden'));
        customersContent.forEach(el => el.classList.add('tw-hidden'));
      } else {
        brandsContent.forEach(el => el.classList.add('tw-hidden'));
        customersContent.forEach(el => el.classList.remove('tw-hidden'));
      }

      // Save preference
      localStorage.setItem('sharedSweepsAudience', audience);
    }

    // Set up click handlers
    buttons.forEach(btn => {
      btn.addEventListener('click', () => switchAudience(btn.dataset.audience));
    });

    // Load saved preference
    const savedAudience = localStorage.getItem('sharedSweepsAudience');
    if (savedAudience && savedAudience !== 'brands') {
      switchAudience(savedAudience);
    }
  });
</script>

{% schema %}
{
  "name": "Hero with Toggle",
  "class": "hero-toggle-section",
  "settings": [
    {
      "type": "header",
      "content": "Section Styling"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Toggle Settings"
    },
    {
      "type": "checkbox",
      "id": "show_toggle",
      "label": "Show audience toggle",
      "default": true
    },
    {
      "type": "text",
      "id": "toggle_brands_label",
      "label": "Brands toggle label",
      "default": "For Brands"
    },
    {
      "type": "text",
      "id": "toggle_customers_label",
      "label": "Customers toggle label",
      "default": "For Customers"
    },
    {
      "type": "header",
      "content": "Brands Content"
    },
    {
      "type": "text",
      "id": "brands_heading",
      "label": "Brands heading",
      "default": "A Better Way for Brands to Run Sweepstakes"
    },
    {
      "type": "textarea",
      "id": "brands_description",
      "label": "Brands description",
      "default": "Shared Sweeps enables brands to give their customers entries into a $100,000 sweepstakes simply by shopping on their site — with no financial risk."
    },
    {
      "type": "text",
      "id": "brands_primary_cta_text",
      "label": "Primary CTA text",
      "default": "Talk to Our Team"
    },
    {
      "type": "select",
      "id": "brands_primary_cta_type",
      "label": "Primary CTA type",
      "options": [
        { "value": "link", "label": "Link" },
        { "value": "modal", "label": "Open contact modal" }
      ],
      "default": "modal"
    },
    {
      "type": "url",
      "id": "brands_primary_cta_link",
      "label": "Primary CTA link (if type is link)"
    },
    {
      "type": "text",
      "id": "brands_secondary_cta_text",
      "label": "Secondary CTA text",
      "default": "See How It Works"
    },
    {
      "type": "url",
      "id": "brands_secondary_cta_link",
      "label": "Secondary CTA link"
    },
    {
      "type": "text",
      "id": "brands_indicator_1",
      "label": "Trust indicator 1",
      "default": "No upfront costs"
    },
    {
      "type": "text",
      "id": "brands_indicator_2",
      "label": "Trust indicator 2",
      "default": "Shopify integrated"
    },
    {
      "type": "text",
      "id": "brands_indicator_3",
      "label": "Trust indicator 3",
      "default": "Trusted by 100+ brands"
    },
    {
      "type": "header",
      "content": "Customers Content"
    },
    {
      "type": "text",
      "id": "customers_heading",
      "label": "Customers heading",
      "default": "Win $100,000 by purchasing from your favorite brands."
    },
    {
      "type": "textarea",
      "id": "customers_description",
      "label": "Customers description",
      "default": "Shop from your favorite brands — and discover new ones you'll love. Earn entries with every dollar you spend and get a real chance at a life-changing prize, with no extra steps required."
    },
    {
      "type": "text",
      "id": "customers_primary_cta_text",
      "label": "Primary CTA text",
      "default": "See How to Enter"
    },
    {
      "type": "url",
      "id": "customers_primary_cta_link",
      "label": "Primary CTA link"
    },
    {
      "type": "text",
      "id": "customers_secondary_cta_text",
      "label": "Secondary CTA text",
      "default": "View Participating Brands"
    },
    {
      "type": "url",
      "id": "customers_secondary_cta_link",
      "label": "Secondary CTA link"
    },
    {
      "type": "text",
      "id": "customers_indicator_1",
      "label": "Trust indicator 1",
      "default": "One $100,000 prize"
    },
    {
      "type": "text",
      "id": "customers_indicator_2",
      "label": "Trust indicator 2",
      "default": "Monthly $10,000 prizes"
    },
    {
      "type": "text",
      "id": "customers_indicator_3",
      "label": "Trust indicator 3",
      "default": "Real winners"
    },
    {
      "type": "text",
      "id": "customers_indicator_4",
      "label": "Trust indicator 4",
      "default": "Trusted brands"
    },
    {
      "type": "header",
      "content": "Additional Options"
    },
    {
      "type": "checkbox",
      "id": "show_trust_indicators",
      "label": "Show trust indicators",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Hero with Toggle",
      "category": "Hero"
    }
  ]
}
{% endschema %}