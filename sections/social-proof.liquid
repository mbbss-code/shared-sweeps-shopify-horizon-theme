{% comment %}
  Social Proof / Results section with audience toggle support
  SEO optimized, ADA compliant, responsive
{% endcomment %}

{%- liquid
  assign bg_color = section.settings.bg_color | default: '#ffffff'
-%}

<style>
  .social-proof-{{ section.id }} {
    background-color: {{ bg_color }};
  }
</style>

<section id="results" class="social-proof-{{ section.id }} tw-py-20 md:tw-py-28" role="region" aria-labelledby="social-proof-heading">
  <div class="tw-container tw-mx-auto tw-px-4">
    
    {%- comment -%} Section Heading {%- endcomment -%}
    <div class="tw-mx-auto tw-mb-12 tw-max-w-2xl tw-text-center">
      <h2 id="social-proof-heading" class="tw-mb-4 tw-text-3xl tw-font-bold tw-text-gray-900 lg:tw-text-4xl xl:tw-text-5xl">
        <span data-brands-content>{{ section.settings.brands_heading | default: 'Real Results from Shopify Brands' }}</span>
        <span data-customers-content class="tw-hidden">{{ section.settings.customers_heading | default: 'Real People. Real Winners.' }}</span>
      </h2>
    </div>

    {%- comment -%} Brands Content - Case Studies {%- endcomment -%}
    <div data-brands-content>
      <div class="tw-grid tw-gap-6 md:tw-grid-cols-2 lg:tw-grid-cols-3">
        {% for block in section.blocks %}
          {% if block.type == 'case_study' %}
            <article class="tw-rounded-lg tw-border tw-border-gray-200 tw-bg-white tw-p-6 tw-shadow-sm">
              
              {%- comment -%} Logo Placeholder {%- endcomment -%}
              <div class="tw-mb-4 tw-flex tw-h-12 tw-w-12 tw-items-center tw-justify-center tw-rounded-lg tw-bg-gray-100">
                {% if block.settings.logo != blank %}
                  <img 
                    src="{{ block.settings.logo | image_url: width: 100 }}"
                    alt="{{ block.settings.brand_name }}"
                    class="tw-h-10 tw-w-10 tw-object-contain"
                    loading="lazy"
                  />
                {% else %}
                  <span class="tw-text-xs tw-text-gray-400">Logo</span>
                {% endif %}
              </div>
              
              <h3 class="tw-mb-2 tw-text-lg tw-font-semibold tw-text-gray-900">
                {{ block.settings.brand_name }}
              </h3>
              
              <p class="tw-mb-3 tw-text-xl tw-font-bold tw-text-purple-600">
                {{ block.settings.stat }}
              </p>
              
              <p class="tw-mb-4 tw-text-sm tw-text-gray-600">
                {{ block.settings.summary }}
              </p>
              
              {% if block.settings.link != blank %}
                <a 
                  href="{{ block.settings.link }}" 
                  class="tw-text-sm tw-font-medium tw-text-purple-600 hover:tw-underline focus:tw-outline-none focus:tw-underline"
                >
                  Read Case Study →
                </a>
              {% endif %}
            </article>
          {% endif %}
        {% endfor %}
      </div>
      
      {%- comment -%} View All CTA {%- endcomment -%}
      {% if section.settings.show_brands_cta %}
        <div class="tw-mt-8 tw-flex tw-justify-center">
          <a 
            href="{{ section.settings.brands_cta_link | default: '/case-studies' }}"
            class="tw-inline-flex tw-items-center tw-justify-center tw-rounded-lg tw-border-2 tw-border-gray-300 tw-bg-white tw-px-6 tw-py-3 tw-text-base tw-font-semibold tw-text-gray-700 tw-transition-all hover:tw-border-gray-400 hover:tw-bg-gray-50 focus:tw-outline-none focus:tw-ring-2 focus:tw-ring-gray-500 focus:tw-ring-offset-2"
          >
            {{ section.settings.brands_cta_text | default: 'See All Case Studies' }}
          </a>
        </div>
      {% endif %}
    </div>

    {%- comment -%} Customers Content - Winners {%- endcomment -%}
    <div data-customers-content class="tw-hidden">
      <div class="tw-mx-auto tw-mb-8 tw-grid tw-max-w-3xl tw-gap-6 md:tw-grid-cols-3">
        {% for block in section.blocks %}
          {% if block.type == 'winner' %}
            <article class="tw-rounded-lg tw-border tw-border-gray-200 tw-bg-white tw-p-6 tw-shadow-sm tw-text-center">
              
              {%- comment -%} Trophy Icon {%- endcomment -%}
              <div class="tw-mx-auto tw-mb-4 tw-flex tw-h-16 tw-w-16 tw-items-center tw-justify-center tw-rounded-full tw-bg-purple-100" aria-hidden="true">
                <svg class="tw-h-8 tw-w-8 tw-text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
                </svg>
              </div>
              
              <h3 class="tw-text-lg tw-font-semibold tw-text-gray-900">
                {{ block.settings.winner_name }}
              </h3>
              
              <p class="tw-mb-3 tw-text-sm tw-text-gray-600">
                {{ block.settings.location }}
              </p>
              
              <p class="tw-text-sm tw-text-gray-600">
                Shopped with: <span class="tw-font-medium tw-text-gray-900">{{ block.settings.brand }}</span>
              </p>
              
              <p class="tw-mt-2 tw-text-2xl tw-font-bold tw-text-purple-600">
                {{ block.settings.prize }}
              </p>
            </article>
          {% endif %}
        {% endfor %}
      </div>
      
      {%- comment -%} View All Winners CTA {%- endcomment -%}
      {% if section.settings.show_customers_cta %}
        <div class="tw-flex tw-justify-center">
          <a 
            href="{{ section.settings.customers_cta_link | default: '/past-winners' }}"
            class="tw-inline-flex tw-items-center tw-justify-center tw-rounded-lg tw-border-2 tw-border-gray-300 tw-bg-white tw-px-6 tw-py-3 tw-text-base tw-font-semibold tw-text-gray-700 tw-transition-all hover:tw-border-gray-400 hover:tw-bg-gray-50 focus:tw-outline-none focus:tw-ring-2 focus:tw-ring-gray-500 focus:tw-ring-offset-2"
          >
            {{ section.settings.customers_cta_text | default: 'See All Winners' }}
          </a>
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Social Proof",
  "class": "social-proof-section",
  "settings": [
    {
      "type": "header",
      "content": "Section Styling"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Headings"
    },
    {
      "type": "text",
      "id": "brands_heading",
      "label": "Brands heading",
      "default": "Real Results from Shopify Brands"
    },
    {
      "type": "text",
      "id": "customers_heading",
      "label": "Customers heading",
      "default": "Real People. Real Winners."
    },
    {
      "type": "header",
      "content": "Brands CTA"
    },
    {
      "type": "checkbox",
      "id": "show_brands_cta",
      "label": "Show brands CTA button",
      "default": true
    },
    {
      "type": "text",
      "id": "brands_cta_text",
      "label": "CTA button text",
      "default": "See All Case Studies"
    },
    {
      "type": "url",
      "id": "brands_cta_link",
      "label": "CTA button link"
    },
    {
      "type": "header",
      "content": "Customers CTA"
    },
    {
      "type": "checkbox",
      "id": "show_customers_cta",
      "label": "Show customers CTA button",
      "default": true
    },
    {
      "type": "text",
      "id": "customers_cta_text",
      "label": "CTA button text",
      "default": "See All Winners"
    },
    {
      "type": "url",
      "id": "customers_cta_link",
      "label": "CTA button link"
    }
  ],
  "blocks": [
    {
      "type": "case_study",
      "name": "Case Study",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Brand logo"
        },
        {
          "type": "text",
          "id": "brand_name",
          "label": "Brand name",
          "default": "Brand Name"
        },
        {
          "type": "text",
          "id": "stat",
          "label": "Key statistic",
          "default": "35.97% increase in ROAS"
        },
        {
          "type": "textarea",
          "id": "summary",
          "label": "Summary",
          "default": "A brief summary of the case study results."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Case study link"
        }
      ]
    },
    {
      "type": "winner",
      "name": "Winner",
      "settings": [
        {
          "type": "text",
          "id": "winner_name",
          "label": "Winner name",
          "default": "Jason H."
        },
        {
          "type": "text",
          "id": "location",
          "label": "Location",
          "default": "Marshall, MO"
        },
        {
          "type": "text",
          "id": "brand",
          "label": "Brand shopped",
          "default": "Synister Speed"
        },
        {
          "type": "text",
          "id": "prize",
          "label": "Prize amount",
          "default": "$10,000"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Social Proof",
      "category": "Content",
      "blocks": [
        {
          "type": "case_study",
          "settings": {
            "brand_name": "Fresh Chile Co",
            "stat": "35.97% increase in ROAS",
            "summary": "A 3-month Shared Sweeps campaign became their top growth channel.",
            "link": "/case-studies/fresh-chile-co"
          }
        },
        {
          "type": "case_study",
          "settings": {
            "brand_name": "Pair of Thieves",
            "stat": "18% increase in gross sales",
            "summary": "Sweepstakes drove more site visits, repeated touches, and channel interaction.",
            "link": "/case-studies/pair-of-thieves"
          }
        },
        {
          "type": "case_study",
          "settings": {
            "brand_name": "Caraway Home",
            "stat": "61% increase in YoY top-line revenue",
            "summary": "Sweepstakes drove substantial growth across email and SMS lists.",
            "link": "/case-studies/caraway-home"
          }
        },
        {
          "type": "winner",
          "settings": {
            "winner_name": "Jason H.",
            "location": "Marshall, MO",
            "brand": "Synister Speed",
            "prize": "$10,000"
          }
        },
        {
          "type": "winner",
          "settings": {
            "winner_name": "Kaitlin M.",
            "location": "Montague, NJ",
            "brand": "Cirkul",
            "prize": "$100,000"
          }
        },
        {
          "type": "winner",
          "settings": {
            "winner_name": "Dre C.",
            "location": "Bozeman, MT",
            "brand": "Caraway Home",
            "prize": "$100,000"
          }
        }
      ]
