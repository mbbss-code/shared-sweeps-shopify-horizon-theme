{% comment %}
  Past Winners Grid Section
  Expandable winner cards with show more/less toggle
  SEO optimized with ItemList structured data
  ADA compliant with live region announcements
  Responsive grid: 1 > 2 > 3 > 4 columns
{% endcomment %}

{%- liquid
  assign bg_color = section.settings.bg_color | default: '#f3f4f6'
  assign border_color = section.settings.border_color | default: '#e5e7eb'
  assign card_bg = section.settings.card_bg | default: '#ffffff'
  assign card_border = section.settings.card_border | default: '#e5e7eb'
  assign name_color = section.settings.name_color | default: '#111827'
  assign meta_color = section.settings.meta_color | default: '#4b5563'
  assign icon_color = section.settings.icon_color | default: '#9ca3af'
  assign brand_color = section.settings.brand_color | default: '#111827'
  assign accent_color = section.settings.accent_color | default: '#3099d3'
  assign prize_badge_bg = section.settings.prize_badge_bg | default: '#3099d3'
  assign prize_badge_text = section.settings.prize_badge_text | default: '#ffffff'
  assign placeholder_bg = section.settings.placeholder_bg | default: '#f3f4f6'
  assign placeholder_text = section.settings.placeholder_text | default: '#9ca3af'
  assign btn_bg = section.settings.btn_bg | default: '#ffffff'
  assign btn_text = section.settings.btn_text | default: '#374151'
  assign btn_border = section.settings.btn_border | default: '#d1d5db'
  assign btn_hover_bg = section.settings.btn_hover_bg | default: '#f9fafb'
  assign btn_hover_text = section.settings.btn_hover_text | default: '#374151'
  assign btn_hover_border = section.settings.btn_hover_border | default: '#9ca3af'
  assign initial_count = section.settings.initial_winner_count | default: 6 | plus: 0
  assign winner_index = 0
  assign total_winners = 0
-%}

{%- comment -%} Count total winners for toggle visibility logic {%- endcomment -%}
{% for block in section.blocks %}
  {% if block.type == 'winner' %}
    {% assign total_winners = total_winners | plus: 1 %}
  {% endif %}
{% endfor %}

<style>
  .past-winners-grid-{{ section.id }} {
    background-color: {{ bg_color }};
    border-color: {{ border_color }};
  }
  .past-winners-grid-{{ section.id }} .acs-card {
    background-color: {{ card_bg }};
    border-color: {{ card_border }};
  }
  .past-winners-grid-{{ section.id }} .acs-card:hover {
    box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
  }
  .past-winners-grid-{{ section.id }} .acs-prize-badge {
    background-color: {{ prize_badge_bg }}1a;
    color: {{ prize_badge_text }};
  }
  .past-winners-grid-{{ section.id }} .acs-prize-amount {
    color: {{ accent_color }};
  }
  .past-winners-grid-{{ section.id }} .acs-toggle-btn {
    background-color: {{ btn_bg }};
    color: {{ btn_text }};
    border: 2px solid {{ btn_border }};
  }
  .past-winners-grid-{{ section.id }} .acs-toggle-btn:hover {
    background-color: {{ btn_hover_bg }};
    color: {{ btn_hover_text }};
    border-color: {{ btn_hover_border }};
  }
  .past-winners-grid-{{ section.id }} .acs-toggle-btn:focus {
    outline: none;
    box-shadow: 0 0 0 2px {{ btn_border }}, 0 0 0 4px #fff;
  }
</style>

{%- comment -%} JSON-LD ItemList Structured Data {%- endcomment -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Past Sweepstakes Winners",
  "description": "Real winners from Shared Sweeps sweepstakes campaigns",
  "numberOfItems": {{ total_winners }},
  "itemListElement": [
    {% assign ld_index = 0 %}
    {% for block in section.blocks %}
      {% if block.type == 'winner' %}
        {% assign ld_index = ld_index | plus: 1 %}
        {% unless ld_index == 1 %},{% endunless %}
        {
          "@type": "ListItem",
          "position": {{ ld_index }},
          "item": {
            "@type": "Person",
            "name": {{ block.settings.name | json }},
            "address": {
              "@type": "PostalAddress",
              "addressLocality": {{ block.settings.city | json }},
              "addressRegion": {{ block.settings.state | json }}
            },
            "award": {{ block.settings.prize | default: "$100,000" | json }}
            {% if block.settings.image != blank %}
              ,"image": "{{ block.settings.image | image_url: width: 600 }}"
            {% endif %}
          }
        }
      {% endif %}
    {% endfor %}
  ]
}
</script>

<section class="past-winners-grid-{{ section.id }} tw-border-y tw-py-20 md:tw-py-28" role="region" aria-labelledby="past-winners-grid-heading">
  <div class="tw-container tw-mx-auto tw-px-4">
    <h2 id="past-winners-grid-heading" class="tw-sr-only">Past Winners</h2>

    {%- comment -%} Winners Grid {%- endcomment -%}
    <div class="tw-grid tw-gap-6 sm:tw-grid-cols-2 md:tw-grid-cols-3 xl:tw-grid-cols-4" role="list" aria-label="Past winners">
      {% assign winner_index = 0 %}
      {% for block in section.blocks %}
        {% if block.type == 'winner' %}
          {% assign winner_index = winner_index | plus: 1 %}

          <article 
            class="acs-card tw-rounded-lg tw-border tw-overflow-hidden tw-shadow-sm tw-transition-all {% if winner_index > initial_count %}tw-hidden{% endif %}"
            role="listitem"
            {% if winner_index > initial_count %}data-winner-extra{% endif %}
            itemscope itemtype="https://schema.org/Person"
          >
            {%- comment -%} Winner Image {%- endcomment -%}
            {% if block.settings.image != blank %}
              <div class="tw-aspect-[4/3] tw-overflow-hidden">
                <img
                  src="{{ block.settings.image | image_url: width: 600 }}"
                  srcset="{{ block.settings.image | image_url: width: 300 }} 300w, {{ block.settings.image | image_url: width: 600 }} 600w, {{ block.settings.image | image_url: width: 900 }} 900w"
                  sizes="(max-width: 640px) 100vw, (max-width: 768px) 50vw, (max-width: 1280px) 33vw, 25vw"
                  alt="{{ block.settings.name }} — {{ block.settings.prize | default: '$100,000' }} sweepstakes winner from {{ block.settings.city }}, {{ block.settings.state }}"
                  class="tw-h-full tw-w-full tw-object-cover"
                  loading="lazy"
                  itemprop="image"
                  width="600"
                  height="450"
                />
              </div>
            {% else %}
              <div class="tw-aspect-[4/3] tw-flex tw-items-center tw-justify-center" style="background-color: {{ placeholder_bg }};" aria-hidden="true">
                <span class="tw-text-sm" style="color: {{ placeholder_text }};">Photo coming soon</span>
              </div>
            {% endif %}

            {%- comment -%} Winner Info {%- endcomment -%}
            <div class="tw-p-5">

              {%- comment -%} Winner Name {%- endcomment -%}
              <h3 class="tw-mb-2 tw-text-lg tw-font-semibold" style="color: {{ name_color }};" itemprop="name">
                {{ block.settings.name }}
              </h3>

              {%- comment -%} Location {%- endcomment -%}
              <div 
                class="tw-mb-3 tw-flex tw-items-center tw-gap-1.5 tw-text-sm"
                style="color: {{ meta_color }};"
                itemprop="address" itemscope itemtype="https://schema.org/PostalAddress"
              >
                <svg class="tw-h-3.5 tw-w-3.5 tw-shrink-0" style="color: {{ icon_color }};" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
                <span>
                  <span itemprop="addressLocality">{{ block.settings.city }}</span><span class="tw-sr-only">,</span> <span itemprop="addressRegion">{{ block.settings.state }}</span>
                </span>
              </div>

              {%- comment -%} Brand Shopped {%- endcomment -%}
              <div class="tw-mb-4 tw-flex tw-items-center tw-gap-1.5 tw-text-sm" style="color: {{ meta_color }};">
                <svg class="tw-h-3.5 tw-w-3.5 tw-shrink-0" style="color: {{ icon_color }};" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
                </svg>
                <span>Shopped at <strong class="tw-font-medium" style="color: {{ brand_color }};">{{ block.settings.brand }}</strong></span>
              </div>

              {%- comment -%} Prize Amount {%- endcomment -%}
              <div class="acs-prize-badge tw-rounded-lg tw-px-3 tw-py-2 tw-text-center">
                <span class="acs-prize-amount tw-text-xl tw-font-bold" itemprop="award">
                  {{ block.settings.prize | default: '$100,000' }}
                </span>
              </div>
            </div>
          </article>
        {% endif %}
      {% endfor %}
    </div>

    {%- comment -%} Show More / Show Less Toggle {%- endcomment -%}
    {% if total_winners > initial_count %}
      <div class="tw-mt-8 tw-text-center">
        <button
          type="button"
          class="acs-toggle-btn tw-inline-flex tw-items-center tw-justify-center tw-rounded-lg tw-px-6 tw-py-3 tw-text-base tw-font-semibold tw-transition-all"
          data-toggle-winners
          aria-expanded="false"
          aria-controls="past-winners-grid"
        >
          <span data-toggle-text-expand>{{ section.settings.show_more_text | default: 'Show all winners' }}</span>
          <span data-toggle-text-collapse class="tw-hidden">{{ section.settings.show_less_text | default: 'Show fewer' }}</span>
        </button>
      </div>
    {% endif %}
  </div>
</section>

{%- comment -%} Screen reader live region for toggle state announcements {%- endcomment -%}
<div id="past-winners-live-region" class="tw-sr-only" aria-live="polite" aria-atomic="true"></div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var toggleBtn = document.querySelector('[data-toggle-winners]');
    if (!toggleBtn) return;

    var extraCards = document.querySelectorAll('[data-winner-extra]');
    var expandText = toggleBtn.querySelector('[data-toggle-text-expand]');
    var collapseText = toggleBtn.querySelector('[data-toggle-text-collapse]');
    var liveRegion = document.getElementById('past-winners-live-region');
    var isExpanded = false;

    toggleBtn.addEventListener('click', function() {
      isExpanded = !isExpanded;

      extraCards.forEach(function(card) {
        card.classList.toggle('tw-hidden', !isExpanded);
      });

      expandText.classList.toggle('tw-hidden', isExpanded);
      collapseText.classList.toggle('tw-hidden', !isExpanded);

      toggleBtn.setAttribute('aria-expanded', String(isExpanded));

      if (liveRegion) {
        liveRegion.textContent = isExpanded
          ? 'Showing all ' + extraCards.length + ' additional winners'
          : 'Showing fewer winners';
      }

      if (!isExpanded) {
        var grid = document.querySelector('[role="list"][aria-label="Past winners"]');
        if (grid) {
          grid.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      }
    });
  });
</script>

