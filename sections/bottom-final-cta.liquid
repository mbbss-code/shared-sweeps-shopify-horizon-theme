{% comment %}
  Final CTA section with audience toggle support
  SEO optimized, ADA compliant, responsive
{% endcomment %}

{%- liquid
  assign bg_color = section.settings.bg_color | default: '#ffffff'
-%}

<style>
  .final-cta-{{ section.id }} {
    background-color: {{ bg_color }};
  }
</style>

<section class="final-cta-{{ section.id }} tw-py-20 md:tw-py-28" role="region" aria-labelledby="final-cta-heading">
  <div class="tw-container tw-mx-auto tw-px-4">
    <div class="tw-mx-auto tw-max-w-3xl tw-rounded-lg tw-border-2 tw-border-purple-200 tw-bg-gradient-to-br tw-from-purple-50 tw-to-transparent tw-p-8 tw-text-center tw-shadow-lg md:tw-p-12">
      
      {%- comment -%} Heading {%- endcomment -%}
      <h2 id="final-cta-heading" class="tw-mb-4 tw-text-3xl tw-font-bold tw-text-gray-900 lg:tw-text-4xl xl:tw-text-5xl">
        <span data-brands-content>{{ section.settings.brands_heading | default: 'Ready to Make Your Ad Spend Work Harder?' }}</span>
        <span data-customers-content class="tw-hidden">{{ section.settings.customers_heading | default: 'Ready to Turn Shopping Into a Chance to Win?' }}</span>
      </h2>
      
      {%- comment -%} Description {%- endcomment -%}
      <p class="tw-mx-auto tw-mb-8 tw-max-w-xl tw-text-lg tw-text-gray-600">
        <span data-brands-content>{{ section.settings.brands_description }}</span>
        <span data-customers-content class="tw-hidden">{{ section.settings.customers_description }}</span>
      </p>
      
      {%- comment -%} CTA Button {%- endcomment -%}
      <span data-brands-content>
        {% if section.settings.brands_cta_type == 'modal' %}
          <button 
            type="button"
            class="tw-inline-flex tw-items-center tw-justify-center tw-rounded-lg tw-bg-gradient-to-r tw-from-purple-600 tw-to-pink-600 tw-px-8 tw-py-4 tw-text-lg tw-font-semibold tw-text-white tw-shadow-lg tw-transition-all hover:tw-shadow-xl hover:tw-scale-105 focus:tw-outline-none focus:tw-ring-2 focus:tw-ring-purple-500 focus:tw-ring-offset-2"
            data-contact-modal-trigger
            aria-haspopup="dialog"
          >
            {{ section.settings.brands_cta_text | default: 'Talk to Our Team' }}
            <svg class="tw-ml-2 tw-h-5 tw-w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
            </svg>
          </button>
        {% else %}
          <a 
            href="{{ section.settings.brands_cta_link }}"
            class="tw-inline-flex tw-items-center tw-justify-center tw-rounded-lg tw-bg-gradient-to-r tw-from-purple-600 tw-to-pink-600 tw-px-8 tw-py-4 tw-text-lg tw-font-semibold tw-text-white tw-shadow-lg tw-transition-all hover:tw-shadow-xl hover:tw-scale-105 focus:tw-outline-none focus:tw-ring-2 focus:tw-ring-purple-500 focus:tw-ring-offset-2"
          >
            {{ section.settings.brands_cta_text | default: 'Talk to Our Team' }}
            <svg class="tw-ml-2 tw-h-5 tw-w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
            </svg>
          </a>
        {% endif %}
      </span>
      
      <span data-customers-content class="tw-hidden">
        <a 
          href="{{ section.settings.customers_cta_link | default: '/participating-brands' }}"
          class="tw-inline-flex tw-items-center tw-justify-center tw-rounded-lg tw-bg-gradient-to-r tw-from-purple-600 tw-to-pink-600 tw-px-8 tw-py-4 tw-text-lg tw-font-semibold tw-text-white tw-shadow-lg tw-transition-all hover:tw-shadow-xl hover:tw-scale-105 focus:tw-outline-none focus:tw-ring-2 focus:tw-ring-purple-500 focus:tw-ring-offset-2"
        >
          {{ section.settings.customers_cta_text | default: 'View Participating Brands' }}
          <svg class="tw-ml-2 tw-h-5 tw-w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
          </svg>
        </a>
      </span>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Final CTA",
  "class": "final-cta-section",
  "settings": [
    {
      "type": "header",
      "content": "Section Styling"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Brands Content"
    },
    {
      "type": "text",
      "id": "brands_heading",
      "label": "Brands heading",
      "default": "Ready to Make Your Ad Spend Work Harder?"
    },
    {
      "type": "textarea",
      "id": "brands_description",
      "label": "Brands description",
      "default": "Join Shopify brands turning sweepstakes into one of their most efficient growth channels. Shared Sweeps funds the prize, handles compliance, and helps your ads convert better — so every dollar goes further."
    },
    {
      "type": "text",
      "id": "brands_cta_text",
      "label": "CTA button text",
      "default": "Talk to Our Team"
    },
    {
      "type": "select",
      "id": "brands_cta_type",
      "label": "CTA type",
      "options": [
        { "value": "link", "label": "Link" },
        { "value": "modal", "label": "Open contact modal" }
      ],
      "default": "modal"
    },
    {
      "type": "url",
      "id": "brands_cta_link",
      "label": "CTA link (if type is link)"
    },
    {
      "type": "header",
      "content": "Customers Content"
    },
    {
      "type": "text",
      "id": "customers_heading",
      "label": "Customers heading",
      "default": "Ready to Turn Shopping Into a Chance to Win?"
    },
    {
      "type": "textarea",
      "id": "customers_description",
      "label": "Customers description",
      "default": "Every purchase counts. Shop participating brands and earn entries toward a real $100,000 prize."
    },
    {
      "type": "text",
      "id": "customers_cta_text",
      "label": "CTA button text",
      "default": "View Participating Brands"
    },
    {
      "type": "url",
      "id": "customers_cta_link",
      "label": "CTA link"
    }
  ],
  "presets": [
    {
      "name": "Final CTA",
      "category": "Call to Action"
    }
  ]
}
{% endschema %}