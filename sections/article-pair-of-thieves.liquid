{%- comment -%}── Collect blocks by type ──{%- endcomment -%}
{%- assign stat_blocks      = section.blocks | where: 'type', 'stat_card' -%}
{%- assign challenge_blocks = section.blocks | where: 'type', 'challenge_card' -%}
{%- assign solution_blocks  = section.blocks | where: 'type', 'solution_item' -%}
{%- assign result_blocks    = section.blocks | where: 'type', 'result_card' -%}

<article class="cs-wrap" aria-label="{{ section.settings.hero_title | default: article.title | escape }}">

  {%- comment -%}── JSON-LD Structured Data ──{%- endcomment -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": {{ section.settings.hero_title | default: article.title | json }},
      "description": {{ section.settings.hero_description | default: article.excerpt | strip_html | json }},
      "author": {
        "@type": "Organization",
        "name": {{ shop.name | json }}
      },
      "publisher": {
        "@type": "Organization",
        "name": {{ shop.name | json }},
        "logo": {
          "@type": "ImageObject",
          "url": {{ shop.brand.logo | image_url: width: 600 | prepend: 'https:' | json }}
        }
      },
      "datePublished": {{ article.published_at | date: '%Y-%m-%dT%H:%M:%S%z' | json }},
      "dateModified": {{ article.updated_at | date: '%Y-%m-%dT%H:%M:%S%z' | json }},
      "mainEntityOfPage": {{ request.origin | append: article.url | json }}
    }
  </script>

  {%- comment -%}
  ════════════════════════════════════════
  §1  HERO
  ════════════════════════════════════════
  {%- endcomment -%}
  <header class="tw-relative tw-overflow-hidden tw-px-4 tw-pb-16 tw-pt-20 md:tw-pb-24 md:tw-pt-28 lg:tw-pb-28 lg:tw-pt-32">
    <div class="tw-mx-auto tw-max-w-7xl">

      {%- if section.settings.back_link_text != blank and section.settings.back_link_url != blank -%}
        <nav aria-label="Breadcrumb" class="tw-mb-8 md:tw-mb-10">
          <a
            href="{{ section.settings.back_link_url }}"
            class="cs-muted tw-inline-flex tw-items-center tw-gap-1 tw-transition-colors hover:tw-opacity-80"
            style="font-size: var(--cs-fs-small)"
          >
            {{ icon_arrow_left }}
            {{ section.settings.back_link_text }}
          </a>
        </nav>
      {%- endif -%}

      <div class="tw-grid tw-items-center tw-gap-8 md:tw-gap-12 md:tw-grid-cols-5">
        {%- comment -%}── Left: Copy (3 cols) ──{%- endcomment -%}
        <div class="md:tw-col-span-3">
          {%- if section.settings.hero_eyebrow != blank -%}
            <p
              class="cs-primary tw-mb-3 tw-font-semibold tw-uppercase tw-tracking-widest md:tw-mb-4"
              style="font-size: var(--cs-fs-small)"
            >
              {{ section.settings.hero_eyebrow }}
            </p>
          {%- endif -%}

          {%- if section.settings.hero_title != blank -%}
            <h1
              class="cs-heading tw-mb-4 tw-font-bold tw-leading-tight md:tw-mb-6"
              style="font-size: clamp(1.75rem, 4vw, var(--cs-fs-hero))"
            >
              {{ section.settings.hero_title }}
            </h1>
          {%- endif -%}

          {%- if section.settings.hero_description != blank -%}
            <p
              class="cs-muted tw-mb-6 tw-max-w-xl tw-leading-relaxed md:tw-mb-8"
              style="font-size: var(--cs-fs-body)"
            >
              {{ section.settings.hero_description }}
            </p>
          {%- endif -%}

          {%- if section.settings.hero_btn_text != blank -%}
            <button
              type="button"
              class="cs-btn tw-px-6 tw-py-3 md:tw-px-8 md:tw-py-4"
              style="font-size: var(--cs-fs-body)"
              data-contact-modal-trigger
              aria-haspopup="dialog"
            >
              {{ section.settings.hero_btn_text }}
              {{ icon_arrow_right }}
            </button>
          {%- endif -%}
        </div>

        {%- comment -%}── Right: Hero stat card (2 cols) ──{%- endcomment -%}
        {%- if section.settings.stat_card_label != blank -%}
          <div class="md:tw-col-span-2">
            <div
              class="cs-card tw-rounded-xl tw-p-6 tw-text-center tw-shadow-lg md:tw-p-8"
              style="border-color: {{ c_primary }}33"
            >
              {%- if section.settings.stat_card_label != blank -%}
                <p
                  class="cs-muted tw-mb-1 tw-font-medium tw-uppercase tw-tracking-wider"
                  style="font-size: var(--cs-fs-small)"
                >
                  {{ section.settings.stat_card_label }}
                </p>
              {%- endif -%}

              <div class="tw-flex tw-items-center tw-justify-center tw-gap-3 tw-my-2">
                {%- if section.settings.stat_card_before != blank -%}
                  <span
                    class="cs-muted tw-font-bold tw-line-through tw-opacity-50"
                    style="font-size: var(--cs-fs-stat); text-decoration-color: #ef4444"
                  >
                    {{ section.settings.stat_card_before }}
                  </span>
                {%- endif -%}

                {%- if section.settings.stat_card_before != blank and section.settings.stat_card_after != blank -%}
                  <span class="cs-primary">{{ icon_arrow_right }}</span>
                {%- endif -%}

                {%- if section.settings.stat_card_after != blank -%}
                  <span class="cs-primary tw-font-bold" style="font-size: var(--cs-fs-stat)">
                    {{ section.settings.stat_card_after }}
                  </span>
                {%- endif -%}
              </div>

              {%- if section.settings.stat_card_caption != blank -%}
                <p class="cs-muted tw-mt-2" style="font-size: var(--cs-fs-small)">
                  {{ section.settings.stat_card_caption }}
                </p>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}
      </div>
    </div>

    {%- comment -%}── Decorative blur ──{%- endcomment -%}
    <div
      class="tw-pointer-events-none tw-absolute -tw-top-40 tw-left-1/2 -tw-z-10 tw-h-96 tw-w-96 -tw-translate-x-1/2 tw-rounded-full tw-blur-3xl"
      style="background: {{ c_primary }}0D"
      aria-hidden="true"
    ></div>
  </header>

  {%- comment -%}
  ════════════════════════════════════════
  §2  KEY RESULTS
  ════════════════════════════════════════
  {%- endcomment -%}
  {%- if stat_blocks.size > 0 -%}
    <section
      class="tw-border-y tw-py-12 md:tw-py-16 lg:tw-py-20"
      style="border-color: {{ c_card_border }}80; background: {{ c_bg_alt }}"
      aria-label="Key results"
    >
      <div class="tw-mx-auto tw-max-w-7xl tw-px-4">
        <div class="tw-grid tw-gap-4 sm:tw-grid-cols-2 lg:tw-grid-cols-{{ stat_blocks.size | at_most: 4 }} md:tw-gap-6">
          {%- for block in stat_blocks -%}
            <div class="cs-card tw-rounded-xl tw-p-5 tw-text-center md:tw-p-6" {{ block.shopify_attributes }}>
              {%- assign blk_icon = block.settings.icon -%}
              {%- if blk_icon != blank -%}
                <div class="cs-primary tw-mx-auto tw-mb-3 tw-h-7 tw-w-7">
                  {%- case blk_icon -%}
                    {%- when 'trending_down' -%}{{ icon_trending_down }}
                    {%- when 'trending_up' -%}{{ icon_trending_up }}
                    {%- when 'repeat' -%}{{ icon_repeat }}
                    {%- when 'bar_chart' -%}{{ icon_bar_chart }}
                    {%- when 'package' -%}{{ icon_package }}
                    {%- when 'users' -%}{{ icon_users }}
                    {%- when 'sparkles' -%}{{ icon_sparkles }}
                    {%- when 'zap' -%}{{ icon_zap }}
                    {%- when 'shield' -%}{{ icon_shield }}
                    {%- when 'target' -%}{{ icon_target }}
                  {%- endcase -%}
                </div>
              {%- endif -%}

              {%- if block.settings.value != blank -%}
                <p class="cs-heading tw-font-bold" style="font-size: var(--cs-fs-stat)">
                  {{ block.settings.value }}
                </p>
              {%- endif -%}

              {%- if block.settings.label != blank -%}
                <p class="cs-muted tw-mt-2" style="font-size: var(--cs-fs-small)">
                  {{ block.settings.label }}
                </p>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>
      </div>
    </section>
  {%- endif -%}

  {%- comment -%}
  ════════════════════════════════════════
  §3  ABOUT THE BRAND
  ════════════════════════════════════════
  {%- endcomment -%}
  {%- if section.settings.about_heading != blank or section.settings.about_body_1 != blank -%}
    <section class="tw-py-16 md:tw-py-20 lg:tw-py-28" aria-label="About the brand">
      <div class="tw-mx-auto tw-max-w-7xl tw-px-4">
        <div class="tw-grid tw-items-center tw-gap-8 md:tw-gap-12 md:tw-grid-cols-2">
          <div>
            {%- if section.settings.about_heading != blank -%}
              <h2
                class="cs-heading tw-mb-4 tw-font-bold md:tw-mb-6"
                style="font-size: clamp(1.5rem, 3vw, var(--cs-fs-section))"
              >
                {{ section.settings.about_heading }}
              </h2>
            {%- endif -%}

            {%- if section.settings.about_body_1 != blank -%}
              <p class="cs-muted tw-mb-4 tw-leading-relaxed" style="font-size: var(--cs-fs-body)">
                {{ section.settings.about_body_1 }}
              </p>
            {%- endif -%}

            {%- if section.settings.about_body_2 != blank -%}
              <p class="cs-muted tw-leading-relaxed" style="font-size: var(--cs-fs-body)">
                {{ section.settings.about_body_2 }}
              </p>
            {%- endif -%}
          </div>

          {%- if section.settings.about_image != blank -%}
            <figure class="tw-flex tw-items-center tw-justify-center">
              {{
                section.settings.about_image
                | image_url: width: 800
                | image_tag:
                    class: 'tw-w-full tw-rounded-2xl tw-object-cover',
                    loading: 'lazy',
                    widths: '400,600,800',
                    sizes: '(min-width: 768px) 50vw, 100vw',
                    alt: section.settings.about_image_alt
              }}
            </figure>
          {%- endif -%}
        </div>
      </div>
    </section>
  {%- endif -%}

  {%- comment -%}
  ════════════════════════════════════════
  §4  THE CHALLENGE
  ════════════════════════════════════════
  {%- endcomment -%}
  {%- if section.settings.challenge_heading != blank or challenge_blocks.size > 0 -%}
    <section
      class="tw-py-16 md:tw-py-20 lg:tw-py-28"
      style="background: var(--cs-bg-alt)"
      aria-label="The challenge"
    >
      <div class="tw-mx-auto tw-max-w-7xl tw-px-4">

        {%- if section.settings.challenge_heading != blank or section.settings.challenge_description != blank -%}
          <div class="tw-mx-auto tw-mb-10 tw-max-w-3xl tw-text-center md:tw-mb-12">
            {%- if section.settings.challenge_heading != blank -%}
              <h2
                class="cs-heading tw-mb-3 tw-font-bold md:tw-mb-4"
                style="font-size: clamp(1.5rem, 3vw, var(--cs-fs-section))"
              >
                {{ section.settings.challenge_heading }}
              </h2>
            {%- endif -%}

            {%- if section.settings.challenge_description != blank -%}
              <p class="cs-muted tw-leading-relaxed" style="font-size: var(--cs-fs-body)">
                {{ section.settings.challenge_description }}
              </p>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- if challenge_blocks.size > 0 -%}
          <div class="tw-grid tw-gap-4 sm:tw-grid-cols-2 lg:tw-grid-cols-{{ challenge_blocks.size | at_most: 4 }} md:tw-gap-6">
            {%- for block in challenge_blocks -%}
              <div class="cs-card tw-rounded-xl tw-p-5 md:tw-p-6" {{ block.shopify_attributes }}>
                {%- assign blk_icon = block.settings.icon -%}
                {%- if blk_icon != blank -%}
                  <div class="cs-primary tw-mb-3 tw-h-8 tw-w-8 md:tw-mb-4">
                    {%- case blk_icon -%}
                      {%- when 'trending_down' -%}{{ icon_trending_down }}
                      {%- when 'trending_up' -%}{{ icon_trending_up }}
                      {%- when 'repeat' -%}{{ icon_repeat }}
                      {%- when 'bar_chart' -%}{{ icon_bar_chart }}
                      {%- when 'package' -%}{{ icon_package }}
                      {%- when 'users' -%}{{ icon_users }}
                      {%- when 'sparkles' -%}{{ icon_sparkles }}
                      {%- when 'zap' -%}{{ icon_zap }}
                      {%- when 'shield' -%}{{ icon_shield }}
                      {%- when 'target' -%}{{ icon_target }}
                    {%- endcase -%}
                  </div>
                {%- endif -%}

                {%- if block.settings.title != blank -%}
                  <h3
                    class="cs-heading tw-mb-2 tw-font-semibold"
                    style="font-size: var(--cs-fs-body)"
                  >
                    {{ block.settings.title }}
                  </h3>
                {%- endif -%}

                {%- if block.settings.body != blank -%}
                  <p class="cs-muted tw-leading-relaxed" style="font-size: var(--cs-fs-small)">
                    {{ block.settings.body }}
                  </p>
                {%- endif -%}
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </section>
  {%- endif -%}

  {%- comment -%}
  ════════════════════════════════════════
  §5  THE SOLUTION
  ════════════════════════════════════════
  {%- endcomment -%}
  {%- if section.settings.solution_heading != blank or solution_blocks.size > 0 -%}
    <section class="tw-py-16 md:tw-py-20 lg:tw-py-28" aria-label="The solution">
      <div class="tw-mx-auto tw-max-w-7xl tw-px-4">
        <div class="tw-grid tw-items-start tw-gap-8 md:tw-gap-12 md:tw-grid-cols-2">
          <div>
            {%- if section.settings.solution_heading != blank -%}
              <h2
                class="cs-heading tw-mb-4 tw-font-bold md:tw-mb-6"
                style="font-size: clamp(1.5rem, 3vw, var(--cs-fs-section))"
              >
                {{ section.settings.solution_heading }}
              </h2>
            {%- endif -%}

            {%- if section.settings.solution_body != blank -%}
              <p class="cs-muted tw-leading-relaxed" style="font-size: var(--cs-fs-body)">
                {{ section.settings.solution_body }}
              </p>
            {%- endif -%}
          </div>

          {%- if solution_blocks.size > 0 -%}
            <ul class="tw-space-y-3 md:tw-space-y-4" role="list">
              {%- for block in solution_blocks -%}
                {%- if block.settings.text != blank -%}
                  <li
                    class="tw-flex tw-items-start tw-gap-3"
                    {{ block.shopify_attributes }}
                  >
                    <span class="cs-primary tw-mt-0.5 tw-h-5 tw-w-5 tw-shrink-0">
                      {{ icon_zap }}
                    </span>
                    <span class="cs-muted" style="font-size: var(--cs-fs-body)">
                      {{ block.settings.text }}
                    </span>
                  </li>
                {%- endif -%}
              {%- endfor -%}
            </ul>
          {%- endif -%}
        </div>
      </div>
    </section>
  {%- endif -%}

  {%- comment -%}
  ════════════════════════════════════════
  §6  THE RESULTS
  ════════════════════════════════════════
  {%- endcomment -%}
  {%- if section.settings.results_heading != blank or result_blocks.size > 0 or section.settings.results_media != blank -%}
    <section
      class="tw-border-y tw-py-16 md:tw-py-20 lg:tw-py-28"
      style="border-color: {{ c_card_border }}80; background: {{ c_bg_alt }}"
      aria-label="The results"
    >
      <div class="tw-mx-auto tw-max-w-7xl tw-px-4">
        {%- if section.settings.results_heading != blank -%}
          <h2
            class="cs-heading tw-mb-10 tw-text-center tw-font-bold md:tw-mb-12"
            style="font-size: clamp(1.5rem, 3vw, var(--cs-fs-section))"
          >
            {{ section.settings.results_heading }}
          </h2>
        {%- endif -%}

        <div class="tw-mx-auto tw-grid tw-max-w-6xl tw-items-start tw-gap-8 md:tw-gap-10 md:tw-grid-cols-2">
          {%- comment -%}── Left: Media ──{%- endcomment -%}
          {%- if section.settings.results_media != blank -%}
            <figure class="tw-mx-auto tw-w-full tw-max-w-sm md:tw-mx-0">
              {%- if section.settings.results_video_url != blank -%}
                <div class="tw-relative tw-aspect-[9/16] tw-overflow-hidden tw-rounded-xl tw-shadow-lg">
                  <video
                    class="tw-h-full tw-w-full tw-object-cover"
                    poster="{{ section.settings.results_media | image_url: width: 600 }}"
                    controls
                    preload="none"
                    playsinline
                    aria-label="{{ section.settings.results_media_alt | default: 'Case study video' | escape }}"
                  >
                    <source src="{{ section.settings.results_video_url }}" type="video/mp4">
                  </video>
                </div>
              {%- else -%}
                {{
                  section.settings.results_media
                  | image_url: width: 600
                  | image_tag:
                      class: 'tw-w-full tw-rounded-xl tw-shadow-lg tw-object-cover',
                      loading: 'lazy',
                      widths: '300,400,600',
                      sizes: '(min-width: 768px) 384px, 100vw',
                      alt: section.settings.results_media_alt
                }}
              {%- endif -%}
            </figure>
          {%- endif -%}

          {%- comment -%}── Right: Result cards ──{%- endcomment -%}
          {%- if result_blocks.size > 0 -%}
            <div class="tw-space-y-4 md:tw-space-y-6">
              {%- for block in result_blocks -%}
                <div
                  class="cs-card tw-flex tw-items-start tw-gap-4 tw-rounded-xl tw-p-5 md:tw-gap-5 md:tw-p-6 lg:tw-p-8"
                  {{ block.shopify_attributes }}
                >
                  {%- assign blk_icon = block.settings.icon -%}
                  {%- if blk_icon != blank -%}
                    <span class="cs-primary tw-mt-0.5 tw-h-7 tw-w-7 tw-shrink-0">
                      {%- case blk_icon -%}
                        {%- when 'trending_down' -%}{{ icon_trending_down }}
                        {%- when 'trending_up' -%}{{ icon_trending_up }}
                        {%- when 'repeat' -%}{{ icon_repeat }}
                        {%- when 'bar_chart' -%}{{ icon_bar_chart }}
                        {%- when 'package' -%}{{ icon_package }}
                        {%- when 'users' -%}{{ icon_users }}
                        {%- when 'sparkles' -%}{{ icon_sparkles }}
                        {%- when 'zap' -%}{{ icon_zap }}
                        {%- when 'shield' -%}{{ icon_shield }}
                        {%- when 'target' -%}{{ icon_target }}
                      {%- endcase -%}
                    </span>
                  {%- endif -%}

                  <div>
                    {%- if block.settings.title != blank -%}
                      <h3
                        class="cs-heading tw-mb-1 tw-font-semibold"
                        style="font-size: var(--cs-fs-body)"
                      >
                        {{ block.settings.title }}
                      </h3>
                    {%- endif -%}

                    {%- if block.settings.body != blank -%}
                      <p class="cs-muted tw-leading-relaxed" style="font-size: var(--cs-fs-small)">
                        {{ block.settings.body }}
                      </p>
                    {%- endif -%}
                  </div>
                </div>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>
      </div>
    </section>
  {%- endif -%}

  {%- comment -%}
  ════════════════════════════════════════
  §7  TESTIMONIAL
  ════════════════════════════════════════
  {%- endcomment -%}
  {%- if section.settings.testimonial_quote != blank -%}
    <section class="tw-py-16 md:tw-py-20 lg:tw-py-28" aria-label="Testimonial">
      <div class="tw-mx-auto tw-max-w-3xl tw-px-4 tw-text-center">
        <div class="cs-primary tw-mx-auto tw-mb-5 tw-h-10 tw-w-10 tw-opacity-30 md:tw-mb-6" aria-hidden="true">
          {{ icon_quote }}
        </div>

        <blockquote>
          <p
            class="cs-heading tw-font-semibold tw-leading-relaxed"
            style="font-size: clamp(1.125rem, 2.5vw, 1.5rem)"
          >
            "{{ section.settings.testimonial_quote }}"
          </p>

          {%- if section.settings.testimonial_attribution != blank -%}
            <footer class="tw-mt-5 md:tw-mt-6">
              <cite class="cs-muted tw-not-italic" style="font-size: var(--cs-fs-body)">
                — {{ section.settings.testimonial_attribution }}
              </cite>
            </footer>
          {%- endif -%}
        </blockquote>
      </div>
    </section>
  {%- endif -%}

  {%- comment -%}
  ════════════════════════════════════════
  §8  WHY IT WORKED
  ════════════════════════════════════════
  {%- endcomment -%}
  {%- if section.settings.why_heading != blank or section.settings.why_body != blank -%}
    <section
      class="tw-py-16 md:tw-py-20 lg:tw-py-28"
      style="background: var(--cs-bg-alt)"
      aria-label="Why it worked"
    >
      <div class="tw-mx-auto tw-max-w-3xl tw-px-4">
        {%- if section.settings.why_heading != blank -%}
          <h2
            class="cs-heading tw-mb-4 tw-font-bold md:tw-mb-6"
            style="font-size: clamp(1.5rem, 3vw, var(--cs-fs-section))"
          >
            {{ section.settings.why_heading }}
          </h2>
        {%- endif -%}

        {%- if section.settings.why_body != blank -%}
          <p class="cs-muted tw-leading-relaxed" style="font-size: var(--cs-fs-body)">
            {{ section.settings.why_body }}
          </p>
        {%- endif -%}
      </div>
    </section>
  {%- endif -%}

  {%- comment -%}
  ════════════════════════════════════════
  §9  FINAL CTA
  ════════════════════════════════════════
  {%- endcomment -%}
  {%- if section.settings.cta_heading != blank -%}
    <section
      class="tw-py-16 md:tw-py-20 lg:tw-py-28"
      style="background: var(--cs-cta-bg); color: var(--cs-cta-text)"
      aria-label="Call to action"
    >
      <div class="tw-mx-auto tw-max-w-2xl tw-px-4 tw-text-center">
        <h2
          class="tw-mb-3 tw-font-bold tw-leading-tight md:tw-mb-4"
          style="font-size: clamp(1.5rem, 3.5vw, var(--cs-fs-hero)); color: var(--cs-cta-text)"
        >
          {{ section.settings.cta_heading }}
        </h2>

        {%- if section.settings.cta_description != blank -%}
          <p
            class="tw-mx-auto tw-mb-6 tw-max-w-lg tw-leading-relaxed tw-opacity-70 md:tw-mb-8"
            style="font-size: var(--cs-fs-body)"
          >
            {{ section.settings.cta_description }}
          </p>
        {%- endif -%}

        <div class="tw-flex tw-flex-col tw-items-center tw-gap-3 sm:tw-flex-row sm:tw-justify-center sm:tw-gap-4">
          {%- if section.settings.cta_btn_primary_text != blank -%}
            <button
              type="button"
              class="cs-btn tw-px-6 tw-py-3 md:tw-px-8 md:tw-py-4"
              style="font-size: var(--cs-fs-body)"
              data-contact-modal-trigger
              aria-haspopup="dialog"
            >
              {{ section.settings.cta_btn_primary_text }}
              {{ icon_arrow_right }}
            </button>
          {%- endif -%}

          {%- if section.settings.cta_btn_secondary_text != blank and section.settings.cta_btn_secondary_url != blank -%}
          <a
              href="{{ section.settings.cta_btn_secondary_url }}"
              class="cs-btn-outline tw-px-5 tw-py-3 md:tw-px-6"
              style="font-size: var(--cs-fs-body); color: var(--cs-cta-text); border-color: {{ c_cta_text }}4D"
            >
              {{ section.settings.cta_btn_secondary_text }}
            </a>
          {%- endif -%}
        </div>
      </div>
    </section>
  {%- endif -%}

</article>

