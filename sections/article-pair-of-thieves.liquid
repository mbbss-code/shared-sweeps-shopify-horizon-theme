{% comment %}
  ══════════════════════════════════════════════════════════
  Section: article-case-study
  ──────────────────────────────────────────────────────────
  Full-page case-study template for Shopify blog articles.

  • Semantic HTML5 (article, section, header, figure, blockquote)
  • ADA / WCAG 2.1 AA (alt text, aria, roles, focus-visible, heading hierarchy)
  • SEO (JSON-LD Article structured data, logical heading tree)
  • Every element auto-hides when its schema value is blank
  • All colours, font sizes, button labels schema-driven
  • Uses 'tw-' Tailwind CSS prefix
  ══════════════════════════════════════════════════════════
{% endcomment %}

{%- liquid
  comment
    ── Colour aliases ──
  endcomment
  assign c_primary         = section.settings.color_primary
  assign c_heading         = section.settings.color_heading
  assign c_body            = section.settings.color_body
  assign c_muted           = section.settings.color_muted
  assign c_bg              = section.settings.color_bg
  assign c_bg_alt          = section.settings.color_bg_alt
  assign c_card_bg         = section.settings.color_card_bg
  assign c_card_border     = section.settings.color_card_border
  assign c_cta_bg          = section.settings.color_cta_section_bg
  assign c_cta_text        = section.settings.color_cta_section_text
  assign c_btn_bg          = section.settings.color_btn_bg
  assign c_btn_text        = section.settings.color_btn_text
  assign c_btn_outline_bdr = section.settings.color_btn_outline_border
  assign c_btn_outline_txt = section.settings.color_btn_outline_text

  comment
    ── Font-size aliases ──
  endcomment
  assign fs_hero_heading   = section.settings.fs_hero_heading
  assign fs_section_heading = section.settings.fs_section_heading
  assign fs_body           = section.settings.fs_body
  assign fs_small          = section.settings.fs_small
  assign fs_stat_value     = section.settings.fs_stat_value
-%}

{%- comment -%}── CSS custom properties ──{%- endcomment -%}
{% style %}
  #shopify-section-{{ section.id }} {
    --cs-primary:          {{ c_primary }};
    --cs-heading:          {{ c_heading }};
    --cs-body:             {{ c_body }};
    --cs-muted:            {{ c_muted }};
    --cs-bg:               {{ c_bg }};
    --cs-bg-alt:           {{ c_bg_alt }};
    --cs-card-bg:          {{ c_card_bg }};
    --cs-card-border:      {{ c_card_border }};
    --cs-cta-bg:           {{ c_cta_bg }};
    --cs-cta-text:         {{ c_cta_text }};
    --cs-btn-bg:           {{ c_btn_bg }};
    --cs-btn-text:         {{ c_btn_text }};
    --cs-btn-outline-bdr:  {{ c_btn_outline_bdr }};
    --cs-btn-outline-txt:  {{ c_btn_outline_txt }};
    --cs-fs-hero:          {{ fs_hero_heading }}px;
    --cs-fs-section:       {{ fs_section_heading }}px;
    --cs-fs-body:          {{ fs_body }}px;
    --cs-fs-small:         {{ fs_small }}px;
    --cs-fs-stat:          {{ fs_stat_value }}px;
  }
  /* ── Base resets scoped to section ── */
  .cs-wrap { color: var(--cs-body); background: var(--cs-bg); }
  .cs-wrap *:focus-visible {
    outline: 2px solid var(--cs-primary);
    outline-offset: 2px;
  }
  .cs-heading   { color: var(--cs-heading); }
  .cs-body      { color: var(--cs-body); }
  .cs-muted     { color: var(--cs-muted); }
  .cs-primary   { color: var(--cs-primary); }
  .cs-bg-alt    { background: var(--cs-bg-alt); }
  .cs-card {
    background: var(--cs-card-bg);
    border: 1px solid var(--cs-card-border);
  }
  .cs-btn {
    display: inline-flex;
    align-items: center;
    gap: .375rem;
    background: var(--cs-btn-bg);
    color: var(--cs-btn-text);
    font-weight: 600;
    border-radius: .5rem;
    border: none;
    cursor: pointer;
    transition: opacity .2s, transform .15s;
  }
  .cs-btn:hover  { opacity: .9; transform: translateY(-1px); }
  .cs-btn:active { transform: translateY(0); }
  .cs-btn-outline {
    display: inline-flex;
    align-items: center;
    gap: .375rem;
    background: transparent;
    color: var(--cs-btn-outline-txt);
    border: 1px solid var(--cs-btn-outline-bdr);
    font-weight: 600;
    border-radius: .5rem;
    cursor: pointer;
    transition: background .2s;
  }
  .cs-btn-outline:hover { background: rgba(255,255,255,.1); }
{% endstyle %}

