            { "value": "repeat", "label": "Repeat" },
            { "value": "bar_chart", "label": "Bar Chart" },
            { "value": "package", "label": "Package" },
            { "value": "users", "label": "Users" },
            { "value": "sparkles", "label": "Sparkles" },
            { "value": "zap", "label": "Zap" },
            { "value": "shield", "label": "Shield" },
            { "value": "target", "label": "Target" }
