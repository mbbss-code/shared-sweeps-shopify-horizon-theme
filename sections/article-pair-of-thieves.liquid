    },
    {
      "type": "text",
      "id": "stat_card_caption",
      "label": "Stat card caption",
      "default": "Reduction in blended discount rate"
    },
    {
      "type": "header",
      "content": "── §3 About the Brand ──"
    },
    {
      "type": "text",
      "id": "about_heading",
