    },
    {
      "type": "header",
      "content": "── §5 The Solution ──"
    },
    {
      "type": "text",
      "id": "solution_heading",
      "label": "Heading",
      "default": "The Shared Sweeps Solution"
    },
    {
      "type": "textarea",
      "id": "solution_body",
      "label": "Description",
      "default": "Pair of Thieves partnered with Shared Sweeps to run a $100K giveaway as a strategic alternative to a traditional promotion. Instead of relying on deep discounts, the campaign used a high‑perceived‑value incentive to drive urgency, increase engagement, and support sales goals."
    },
    {
      "type": "header",
      "content": "── §6 The Results ──"
    },
    {
      "type": "text",
      "id": "results_heading",
      "label": "Heading",
      "default": "The Results"
    },
    {
      "type": "image_picker",
