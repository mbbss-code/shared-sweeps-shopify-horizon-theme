      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "trending_down",
          "options": [
            { "value": "trending_down", "label": "Trending Down" },
            { "value": "trending_up", "label": "Trending Up" },
