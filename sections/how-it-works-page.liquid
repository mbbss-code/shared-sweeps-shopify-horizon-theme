      "label": "Meta description (structured data)",
      "default": "Learn how Shared Sweeps works — no risk, no upfront costs, a fully funded sweepstakes for your Shopify store."
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "primary_color",
      "label": "Primary accent color",
      "default": "#9333ea",
      "info": "Buttons, step badges, highlights, solution icons"
    },
    {
      "type": "color",
      "id": "primary_text_color",
      "label": "Button text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "navy_bg_color",
      "label": "Navy section background",
