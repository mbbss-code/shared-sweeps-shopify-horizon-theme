{% comment %}
  Trust Callout Section
  - Centered promotional callout with icon + optional stats and button
  - Transparent background — painted by the Page Ombre Background section
  - Colors driven by section settings (color pickers)
  - ADA compliant, SEO-friendly heading hierarchy
{% endcomment %}

{%- liquid
  assign heading_color = section.settings.heading_color | default: '#ffffff'
  assign description_color = section.settings.description_color | default: '#9fb3d1'
  assign accent_color = section.settings.accent_color | default: '#2f6fed'
  assign stat_label_color = section.settings.stat_label_color | default: '#9fb3d1'
  assign button_bg = section.settings.button_bg | default: '#2f6fed'
  assign button_text = section.settings.button_text_color | default: '#ffffff'
  assign button_hover_bg = section.settings.button_hover_bg | default: '#2456c0'
  assign stat_cols = section.blocks | size | at_most: 4 | at_least: 1
-%}

<style>
  /* Background omitted — the Page Ombre Background paints this section. */
  .trust-callout-{{ section.id }} .acs-icon-chip { background-color: {{ accent_color }}1a; }
  .trust-callout-{{ section.id }} .acs-icon { color: {{ accent_color }}; }
  .trust-callout-{{ section.id }} .acs-heading { color: {{ heading_color }}; }
  .trust-callout-{{ section.id }} .acs-desc { color: {{ description_color }}; }
  .trust-callout-{{ section.id }} .acs-stat-value { color: {{ accent_color }}; }
  .trust-callout-{{ section.id }} .acs-stat-label { color: {{ stat_label_color }}; }

  .trust-callout-{{ section.id }} .acs-stats {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 2rem;
  }
  @media (min-width: 768px) {
    .trust-callout-{{ section.id }} .acs-stats {
      grid-template-columns: repeat({{ stat_cols }}, minmax(0, 1fr));
    }
  }

  .trust-callout-{{ section.id }} .acs-btn {
    background-color: {{ button_bg }};
    color: {{ button_text }};
  }
  .trust-callout-{{ section.id }} .acs-btn:hover { background-color: {{ button_hover_bg }}; }
  .trust-callout-{{ section.id }} .acs-btn:focus-visible {
    outline: none;
    box-shadow: 0 0 0 2px {{ button_bg }}, 0 0 0 4px #fff;
  }
</style>

<section
  id="trust-callout-{{ section.id }}"
  class="trust-callout-{{ section.id }} tw-border-y tw-border-white/10 tw-py-20 md:tw-py-28"
  aria-labelledby="trust-callout-heading-{{ section.id }}"
  {{ section.shopify_attributes }}
>
  <div class="tw-container tw-mx-auto tw-px-4">
    <div class="tw-mx-auto tw-max-w-3xl tw-text-center">
      {%- if section.settings.show_icon -%}
        <div class="acs-icon-chip tw-mx-auto tw-mb-6 tw-flex tw-h-16 tw-w-16 tw-items-center tw-justify-center tw-rounded-full" aria-hidden="true">
          {%- case section.settings.icon -%}
            {%- when 'building' -%}
              <svg class="acs-icon tw-h-8 tw-w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
              </svg>
            {%- when 'shield-check' -%}
              <svg class="acs-icon tw-h-8 tw-w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            {%- when 'users' -%}
              <svg class="acs-icon tw-h-8 tw-w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
              </svg>
            {%- when 'heart' -%}
              <svg class="acs-icon tw-h-8 tw-w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
              </svg>
            {%- when 'sparkles' -%}
              <svg class="acs-icon tw-h-8 tw-w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
              </svg>
            {%- when 'globe' -%}
              <svg class="acs-icon tw-h-8 tw-w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            {%- when 'custom' -%}
              {%- if section.settings.custom_icon != blank -%}
                <img src="{{ section.settings.custom_icon | image_url: width: 64 }}" alt="" class="tw-h-8 tw-w-8 tw-object-contain" width="32" height="32">
              {%- endif -%}
          {%- endcase -%}
        </div>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 id="trust-callout-heading-{{ section.id }}" class="acs-heading tw-mb-6 tw-text-3xl tw-font-bold md:tw-text-4xl">
          {{ section.settings.heading }}
        </h2>
      {%- endif -%}

      {%- if section.settings.description != blank -%}
        <p class="acs-desc tw-text-lg tw-leading-relaxed tw-max-w-2xl tw-mx-auto">
          {{ section.settings.description }}
        </p>
      {%- endif -%}

      {%- if section.settings.show_stats -%}
        <div class="acs-stats tw-mt-12" role="list" aria-label="Key statistics">
          {%- for block in section.blocks -%}
            {%- if block.type == 'stat' -%}
              <div class="tw-text-center" role="listitem" {{ block.shopify_attributes }}>
                <div class="acs-stat-value tw-text-3xl tw-font-bold md:tw-text-4xl" aria-hidden="true">
                  {{ block.settings.stat_value }}
                </div>
                <div class="acs-stat-label tw-mt-2 tw-text-sm">
                  <span class="tw-sr-only">{{ block.settings.stat_value }}</span>
                  {{ block.settings.stat_label }}
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- if section.settings.button_text != blank -%}
        <div class="tw-mt-10">
          <a
            href="{{ section.settings.button_link }}"
            class="acs-btn tw-inline-flex tw-items-center tw-justify-center tw-px-8 tw-py-3 tw-text-base tw-font-medium tw-rounded-lg tw-transition-all tw-duration-200"
          >
            {{ section.settings.button_text }}
            <svg class="tw-ml-2 -tw-mr-1 tw-w-5 tw-h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Trust Callout",
  "tag": "section",
  "class": "trust-callout",
  "settings": [
    {
      "type": "header",
      "content": "Icon"
    },
    {
      "type": "checkbox",
      "id": "show_icon",
      "label": "Show Icon",
      "default": true
    },
    {
      "type": "select",
      "id": "icon",
      "label": "Icon",
      "options": [
        { "value": "building", "label": "Building" },
        { "value": "shield-check", "label": "Shield Check" },
        { "value": "users", "label": "Users" },
        { "value": "heart", "label": "Heart" },
        { "value": "sparkles", "label": "Sparkles" },
        { "value": "globe", "label": "Globe" },
        { "value": "custom", "label": "Custom Image" }
      ],
      "default": "building"
    },
    {
      "type": "image_picker",
      "id": "custom_icon",
      "label": "Custom Icon Image",
      "info": "Used when 'Custom Image' is selected"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "You're in Good Company"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Shared Sweeps partners with Shopify brands across apparel, home, food, and lifestyle. Every brand participates in the same shared sweepstakes — creating more excitement and stronger results for everyone."
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description color",
      "default": "#9fb3d1"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color (icon, stat values, focus)",
      "default": "#2f6fed"
    },
    {
      "type": "color",
      "id": "stat_label_color",
      "label": "Stat label color",
      "default": "#9fb3d1"
    },
    {
      "type": "header",
      "content": "Statistics"
    },
    {
      "type": "checkbox",
      "id": "show_stats",
      "label": "Show Statistics",
      "default": false
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Button background",
      "default": "#2f6fed"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_bg",
      "label": "Button hover background",
      "default": "#2456c0"
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Statistic",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "stat_value",
          "label": "Value",
          "default": "50+"
        },
        {
          "type": "text",
          "id": "stat_label",
          "label": "Label",
          "default": "Brands"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Callout",
      "blocks": []
    }
  ]
}
{% endschema %}
