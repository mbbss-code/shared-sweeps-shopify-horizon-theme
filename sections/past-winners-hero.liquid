{% comment %}
  Past Winners Hero Section
  SEO optimized with JSON-LD + BreadcrumbList, ADA compliant, responsive
{% endcomment %}

{%- liquid
  assign bg_color = section.settings.bg_color | default: '#ffffff'
  assign heading_color = section.settings.heading_color | default: '#000000'
-%}

<style>
  .past-winners-hero-{{ section.id }} {
    background-color: {{ bg_color }};
  }
</style>

{%- comment -%} JSON-LD Structured Data {%- endcomment -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": {{ section.settings.heading | default: "Real People. Real Winners." | json }},
  "description": {{ section.settings.description | default: "Shared Sweeps awards real cash prizes to real shoppers — funded by participating Shopify brands." | json }},
  "url": "{{ shop.url }}{{ page.url }}",
  "isPartOf": {
    "@type": "WebSite",
    "name": {{ shop.name | json }},
    "url": "{{ shop.url }}"
  },
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "{{ shop.url }}"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": {{ section.settings.heading | default: "Past Winners" | json }},
        "item": "{{ shop.url }}{{ page.url }}"
      }
    ]
  }
}
</script>

<section class="past-winners-hero-{{ section.id }} tw-relative tw-overflow-hidden tw-px-4 tw-pb-20 tw-pt-16 md:tw-pb-28 md:tw-pt-24" role="region" aria-labelledby="past-winners-hero-heading">
  <div class="tw-container tw-mx-auto">
    <div class="tw-mx-auto tw-max-w-3xl tw-text-center">

      <h1 
        id="past-winners-hero-heading" 
        class="tw-mb-6 tw-text-4xl tw-font-bold tw-leading-tight lg:tw-text-5xl xl:tw-text-6xl"
        style="color: {{ heading_color }}"
      >
        {{ section.settings.heading | default: 'Real People. Real Winners.' }}
      </h1>

      <p class="tw-mx-auto tw-mb-10 tw-max-w-2xl tw-text-lg tw-text-gray-600 md:tw-text-xl">
        {{ section.settings.description | default: 'Shared Sweeps awards real cash prizes to real shoppers — funded by participating Shopify brands.' }}
      </p>

      {% if section.settings.show_cta %}
        
        <a href="{{ section.settings.cta_link | default: '/how-to-enter' }}"
          class="tw-inline-flex tw-items-center tw-justify-center tw-rounded-lg tw-bg-gradient-to-r tw-from-purple-600 tw-to-pink-600 tw-px-6 tw-py-3 tw-text-base tw-font-semibold tw-text-white tw-shadow-lg tw-transition-all hover:tw-shadow-xl hover:tw-scale-105 focus:tw-outline-none focus:tw-ring-2 focus:tw-ring-purple-500 focus:tw-ring-offset-2"
        >
          {{ section.settings.cta_text | default: 'See How to Enter' }}
          <svg class="tw-ml-2 tw-h-5 tw-w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
          </svg>
        </a>
      {% endif %}
    </div>
  </div>

  {%- comment -%} Background decoration {%- endcomment -%}
  <div class="tw-absolute -tw-top-40 tw-left-1/2 -tw-z-10 tw-h-96 tw-w-96 -tw-translate-x-1/2 tw-rounded-full tw-bg-purple-500/5 tw-blur-3xl" aria-hidden="true"></div>
</section>

{% schema %}
{
  "name": "Past Winners Hero",
  "class": "past-winners-hero-section",
  "settings": [
    {
      "type": "header",
      "content": "Section Styling"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Real People. Real Winners."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Shared Sweeps awards real cash prizes to real shoppers — funded by participating Shopify brands."
    },
    {
      "type": "header",
      "content": "CTA Button"
    },
    {
      "type": "checkbox",
      "id": "show_cta",
      "label": "Show CTA button",
      "default": true
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA button text",
      "default": "See How to Enter"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA button link"
    }
  ],
  "presets": [
    {
      "name": "Past Winners Hero",
      "category": "Hero"
    }
  ]
}
{% endschema %}