{% comment %}
  Past Winners Hero Section
  SEO optimized with JSON-LD + BreadcrumbList, ADA compliant, responsive
{% endcomment %}

{%- liquid
  assign bg_color = section.settings.bg_color | default: '#ffffff'
  assign heading_color = section.settings.heading_color | default: '#000000'
  assign description_color = section.settings.description_color | default: '#4b5563'
  assign decoration_color = section.settings.decoration_color | default: '#3099d3'
  assign btn_bg = section.settings.btn_bg | default: '#3099d3'
  assign btn_text = section.settings.btn_text | default: '#ffffff'
  assign btn_border = section.settings.btn_border | default: '#3099d3'
  assign btn_hover_bg = section.settings.btn_hover_bg | default: '#2780b3'
  assign btn_hover_text = section.settings.btn_hover_text | default: '#ffffff'
  assign btn_hover_border = section.settings.btn_hover_border | default: '#2780b3'
-%}

<style>
  .past-winners-hero-{{ section.id }} {
    background-color: {{ bg_color }};
  }
  .past-winners-hero-{{ section.id }} .acs-cta-btn {
    background-color: {{ btn_bg }};
    color: {{ btn_text }};
    border: 1px solid {{ btn_border }};
  }
  .past-winners-hero-{{ section.id }} .acs-cta-btn:hover {
    background-color: {{ btn_hover_bg }};
    color: {{ btn_hover_text }};
    border-color: {{ btn_hover_border }};
    transform: scale(1.05);
    box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1);
  }
  .past-winners-hero-{{ section.id }} .acs-cta-btn:focus {
    outline: none;
    box-shadow: 0 0 0 2px {{ btn_bg }}, 0 0 0 4px #fff;
  }
</style>

{%- comment -%} JSON-LD Structured Data {%- endcomment -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": {{ section.settings.heading | default: "Real People. Real Winners." | json }},
  "description": {{ section.settings.description | default: "Shared Sweeps awards real cash prizes to real shoppers — funded by participating Shopify brands." | json }},
  "url": "{{ shop.url }}{{ page.url }}",
  "isPartOf": {
    "@type": "WebSite",
    "name": {{ shop.name | json }},
    "url": "{{ shop.url }}"
  },
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "{{ shop.url }}"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": {{ section.settings.heading | default: "Past Winners" | json }},
        "item": "{{ shop.url }}{{ page.url }}"
      }
    ]
  }
}
</script>

<section class="past-winners-hero-{{ section.id }} tw-relative tw-overflow-hidden tw-px-4 tw-pb-20 tw-pt-16 md:tw-pb-28 md:tw-pt-24" role="region" aria-labelledby="past-winners-hero-heading">
  <div class="tw-container tw-mx-auto">
    <div class="tw-mx-auto tw-max-w-3xl tw-text-center">

      <h1 
        id="past-winners-hero-heading" 
        class="tw-mb-6 tw-text-4xl tw-font-bold tw-leading-tight lg:tw-text-5xl xl:tw-text-6xl"
        style="color: {{ heading_color }};"
      >
        {{ section.settings.heading | default: 'Real People. Real Winners.' }}
      </h1>

      <p class="tw-mx-auto tw-mb-10 tw-max-w-2xl tw-text-lg md:tw-text-xl" style="color: {{ description_color }};">
        {{ section.settings.description | default: 'Shared Sweeps awards real cash prizes to real shoppers — funded by participating Shopify brands.' }}
      </p>

      {% if section.settings.show_cta %}
        <a 
          href="{{ section.settings.cta_link | default: '/how-to-enter' }}"
          class="acs-cta-btn tw-inline-flex tw-items-center tw-justify-center tw-rounded-lg tw-px-6 tw-py-3 tw-text-base tw-font-semibold tw-shadow-lg tw-transition-all"
        >
          {{ section.settings.cta_text | default: 'See How to Enter' }}
          <svg class="tw-ml-2 tw-h-5 tw-w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
          </svg>
        </a>
      {% endif %}
    </div>
  </div>

  {%- comment -%} Background decoration {%- endcomment -%}
  {% if section.settings.show_decoration %}
    <div 
      class="tw-absolute -tw-top-40 tw-left-1/2 -tw-z-10 tw-h-96 tw-w-96 -tw-translate-x-1/2 tw-rounded-full tw-blur-3xl"
      style="background-color: {{ decoration_color }}; opacity: 0.05;"
      aria-hidden="true"
    ></div>
  {% endif %}
</section>

{% schema %}
{
  "name": "Past Winners Hero",
  "class": "past-winners-hero-section",
  "settings": [
    {
      "type": "header",
      "content": "Section Styling"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description color",
      "default": "#4b5563"
    },
    {
      "type": "header",
      "content": "CTA Button Colors"
    },
    {
      "type": "color",
      "id": "btn_bg",
      "label": "Background",
      "default": "#3099d3"
    },
    {
      "type": "color",
      "id": "btn_text",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "btn_border",
      "label": "Border color",
      "default": "#3099d3"
    },
    {
      "type": "color",
      "id": "btn_hover_bg",
      "label": "Hover background",
      "default": "#2780b3"
    },
    {
      "type": "color",
      "id": "btn_hover_text",
      "label": "Hover text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "btn_hover_border",
      "label": "Hover border color",
      "default": "#2780b3"
    },
    {
      "type": "header",
      "content": "Background Decoration"
    },
    {
      "type": "checkbox",
      "id": "show_decoration",
      "label": "Show background decoration",
      "default": true
    },
    {
      "type": "color",
      "id": "decoration_color",
      "label": "Decoration color",
      "default": "#3099d3"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Real People. Real Winners."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Shared Sweeps awards real cash prizes to real shoppers — funded by participating Shopify brands."
    },
    {
      "type": "header",
      "content": "CTA Button"
    },
    {
      "type": "checkbox",
      "id": "show_cta",
      "label": "Show CTA button",
      "default": true
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA button text",
      "default": "See How to Enter"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA button link"
    }
  ],
  "presets": [
    {
      "name": "Past Winners Hero",
      "category": "Hero"
    }
  ]
}
{% endschema %}