      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "filter_outline_bg",
      "label": "Inactive filter background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "filter_outline_text",
      "label": "Inactive filter text",
      "default": "#374151"
    },
