      "label": "Heading color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "muted_color",
      "label": "Muted text color",
      "default": "#6b7280"
    },
    {
      "type": "color",
      "id": "primary_color",
      "label": "Primary/accent color",
      "default": "#3b82f6"
    },
    {
      "type": "header",
      "content": "Filter Button Colors"
    },
    {
      "type": "color",
      "id": "filter_bg_color",
      "label": "Active filter background",
      "default": "#3b82f6"
    },
    {
      "type": "color",
      "id": "filter_text_color",
