        },
        {
          "type": "text",
          "id": "metric",
          "label": "Headline metric",
          "default": "$1.5M in revenue"
        },
        {
          "type": "textarea",
          "id": "summary",
          "label": "Summary (shown on hover)",
          "default": "Brief description of results achieved."
        },
        {
          "type": "url",
          "id": "case_study_url",
          "label": "Case study URL"
        },
        {
          "type": "text",
          "id": "link_text",
          "label": "Link text",
          "default": "View Case Study"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "ACS — Filter & Grid",
