{% comment %}
  Participating Brands Hero Section
  - Responsive design with Tailwind CSS
  - ADA Compliant with proper ARIA labels and semantic HTML
  - SEO Optimized with proper heading hierarchy
  - Fully customizable via Shopify schema
{% endcomment %}

{%- liquid
  assign bg_color = section.settings.bg_color | default: '#ffffff'
  assign heading_color = section.settings.heading_color | default: '#111827'
  assign subheading_color = section.settings.subheading_color | default: '#4b5563'
  assign badge_bg = section.settings.badge_bg | default: '#e0f2fe'
  assign badge_text = section.settings.badge_text_color | default: '#0c4a6e'
  assign primary_btn_bg = section.settings.primary_btn_bg | default: '#3099d3'
  assign primary_btn_text = section.settings.primary_btn_text | default: '#ffffff'
  assign primary_btn_border = section.settings.primary_btn_border | default: '#3099d3'
  assign primary_btn_hover_bg = section.settings.primary_btn_hover_bg | default: '#2780b3'
  assign primary_btn_hover_text = section.settings.primary_btn_hover_text | default: '#ffffff'
  assign primary_btn_hover_border = section.settings.primary_btn_hover_border | default: '#2780b3'
  assign secondary_btn_bg = section.settings.secondary_btn_bg | default: '#ffffff'
  assign secondary_btn_text = section.settings.secondary_btn_text | default: '#374151'
  assign secondary_btn_border = section.settings.secondary_btn_border | default: '#d1d5db'
  assign secondary_btn_hover_bg = section.settings.secondary_btn_hover_bg | default: '#f9fafb'
  assign secondary_btn_hover_text = section.settings.secondary_btn_hover_text | default: '#374151'
  assign secondary_btn_hover_border = section.settings.secondary_btn_hover_border | default: '#9ca3af'
  assign border_color = section.settings.section_border_color | default: '#e5e7eb'
  assign pattern_color = section.settings.pattern_color | default: '#3099d3'
  assign trust_text_color = section.settings.trust_text_color | default: '#6b7280'
  assign trust_icon_color = section.settings.trust_icon_color | default: '#22c55e'
-%}

<style>
  .brands-hero-{{ section.id }} {
    background-color: {{ bg_color }};
    border-bottom-color: {{ border_color }};
  }
  .brands-hero-{{ section.id }} .acs-badge {
    background-color: {{ badge_bg }};
    color: {{ badge_text }};
  }
  .brands-hero-{{ section.id }} .acs-primary-btn {
    background-color: {{ primary_btn_bg }};
    color: {{ primary_btn_text }};
    border: 1px solid {{ primary_btn_border }};
  }
  .brands-hero-{{ section.id }} .acs-primary-btn:hover {
    background-color: {{ primary_btn_hover_bg }};
    color: {{ primary_btn_hover_text }};
    border-color: {{ primary_btn_hover_border }};
    box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1);
    transform: translateY(-2px);
  }
  .brands-hero-{{ section.id }} .acs-primary-btn:focus {
    outline: none;
    box-shadow: 0 0 0 2px {{ primary_btn_bg }}, 0 0 0 4px #fff;
  }
  .brands-hero-{{ section.id }} .acs-secondary-btn {
    background-color: {{ secondary_btn_bg }};
    color: {{ secondary_btn_text }};
    border: 1px solid {{ secondary_btn_border }};
  }
  .brands-hero-{{ section.id }} .acs-secondary-btn:hover {
    background-color: {{ secondary_btn_hover_bg }};
    color: {{ secondary_btn_hover_text }};
    border-color: {{ secondary_btn_hover_border }};
  }
  .brands-hero-{{ section.id }} .acs-secondary-btn:focus {
    outline: none;
    box-shadow: 0 0 0 2px {{ secondary_btn_border }}, 0 0 0 4px #fff;
  }
  .brands-hero-{{ section.id }} .acs-trust-icon {
    color: {{ trust_icon_color }};
  }
</style>

<section 
  id="participating-brands-hero"
  class="brands-hero-{{ section.id }} tw-relative tw-overflow-hidden tw-border-b tw-py-20 md:tw-py-28"
  aria-labelledby="hero-heading"
  role="banner"
>
  {%- if section.settings.show_background_pattern -%}
    <div class="tw-absolute tw-inset-0 tw-opacity-5" aria-hidden="true">
      <svg class="tw-h-full tw-w-full" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="hero-pattern-{{ section.id }}" x="0" y="0" width="40" height="40" patternUnits="userSpaceOnUse">
            <circle cx="20" cy="20" r="1.5" fill="{{ pattern_color }}" />
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#hero-pattern-{{ section.id }})" />
      </svg>
    </div>
  {%- endif -%}

  <div class="tw-container tw-mx-auto tw-px-4 tw-relative tw-z-10">
    <div class="tw-mx-auto tw-max-w-3xl tw-text-center">
      {%- if section.settings.badge_text != blank -%}
        <span class="acs-badge tw-inline-block tw-mb-4 tw-px-4 tw-py-1.5 tw-text-sm tw-font-medium tw-rounded-full">
          {{ section.settings.badge_text }}
        </span>
      {%- endif -%}

      <h1 
        id="hero-heading"
        class="tw-mb-6 tw-text-4xl tw-font-bold tw-tracking-tight md:tw-text-5xl lg:tw-text-6xl"
        style="color: {{ heading_color }};"
      >
        {{ section.settings.heading }}
      </h1>

      {%- if section.settings.subheading != blank -%}
        <p class="tw-mb-8 tw-text-lg md:tw-text-xl tw-leading-relaxed" style="color: {{ subheading_color }};">
          {{ section.settings.subheading }}
        </p>
      {%- endif -%}

      {%- if section.settings.button_text != blank -%}
        <div class="tw-flex tw-flex-col sm:tw-flex-row tw-gap-4 tw-justify-center tw-items-center">
          {% if section.settings.button_opens_modal %}
            <button
              type="button"
              class="acs-primary-btn tw-inline-flex tw-items-center tw-justify-center tw-px-8 tw-py-3 tw-text-base tw-font-medium tw-rounded-lg tw-shadow-lg tw-transition-all tw-duration-200"
              data-contact-modal-trigger
              aria-haspopup="dialog"
            >
              {{ section.settings.button_text }}
              {%- if section.settings.show_button_icon -%}
                <svg class="tw-ml-2 -tw-mr-1 tw-w-5 tw-h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                </svg>
              {%- endif -%}
            </button>
          {% else %}
            <a 
              href="{{ section.settings.button_link }}"
              class="acs-primary-btn tw-inline-flex tw-items-center tw-justify-center tw-px-8 tw-py-3 tw-text-base tw-font-medium tw-rounded-lg tw-shadow-lg tw-transition-all tw-duration-200"
            >
              {{ section.settings.button_text }}
              {%- if section.settings.show_button_icon -%}
                <svg class="tw-ml-2 -tw-mr-1 tw-w-5 tw-h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                </svg>
              {%- endif -%}
            </a>
          {% endif %}

          {%- if section.settings.secondary_button_text != blank -%}
            <a 
              href="{{ section.settings.secondary_button_link }}"
              class="acs-secondary-btn tw-inline-flex tw-items-center tw-justify-center tw-px-8 tw-py-3 tw-text-base tw-font-medium tw-rounded-lg tw-transition-all tw-duration-200"
            >
              {{ section.settings.secondary_button_text }}
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if section.settings.show_trust_indicators -%}
        <div class="tw-mt-10 tw-flex tw-flex-wrap tw-justify-center tw-gap-x-8 tw-gap-y-4 tw-text-sm" style="color: {{ trust_text_color }};">
          {%- for block in section.blocks -%}
            {%- if block.type == 'trust_indicator' -%}
              <div class="tw-flex tw-items-center tw-gap-2" {{ block.shopify_attributes }}>
                {%- if block.settings.icon == 'check' -%}
                  <svg class="acs-trust-icon tw-w-5 tw-h-5" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                {%- elsif block.settings.icon == 'shield' -%}
                  <svg class="acs-trust-icon tw-w-5 tw-h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                  </svg>
                {%- elsif block.settings.icon == 'star' -%}
                  <svg class="acs-trust-icon tw-w-5 tw-h-5" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                {%- endif -%}
                <span>{{ block.settings.text }}</span>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Brands Hero",
  "tag": "section",
  "class": "participating-brands-hero",
  "settings": [
    {
      "type": "header",
      "content": "Section Styling"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "section_border_color",
      "label": "Bottom border color",
      "default": "#e5e7eb"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#111827"
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading color",
      "default": "#4b5563"
    },
    {
      "type": "header",
      "content": "Badge Colors"
    },
    {
      "type": "color",
      "id": "badge_bg",
      "label": "Badge background",
      "default": "#e0f2fe"
    },
    {
      "type": "color",
      "id": "badge_text_color",
      "label": "Badge text",
      "default": "#0c4a6e"
    },
    {
      "type": "header",
      "content": "Primary Button Colors"
    },
    {
      "type": "color",
      "id": "primary_btn_bg",
      "label": "Background",
      "default": "#3099d3"
    },
    {
      "type": "color",
      "id": "primary_btn_text",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "primary_btn_border",
      "label": "Border color",
      "default": "#3099d3"
    },
    {
      "type": "color",
      "id": "primary_btn_hover_bg",
      "label": "Hover background",
      "default": "#2780b3"
    },
    {
      "type": "color",
      "id": "primary_btn_hover_text",
      "label": "Hover text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "primary_btn_hover_border",
      "label": "Hover border color",
      "default": "#2780b3"
    },
    {
      "type": "header",
      "content": "Secondary Button Colors"
    },
    {
      "type": "color",
      "id": "secondary_btn_bg",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "secondary_btn_text",
      "label": "Text color",
      "default": "#374151"
    },
    {
      "type": "color",
      "id": "secondary_btn_border",
      "label": "Border color",
      "default": "#d1d5db"
    },
    {
      "type": "color",
      "id": "secondary_btn_hover_bg",
      "label": "Hover background",
      "default": "#f9fafb"
    },
    {
      "type": "color",
      "id": "secondary_btn_hover_text",
      "label": "Hover text color",
      "default": "#374151"
    },
    {
      "type": "color",
      "id": "secondary_btn_hover_border",
      "label": "Hover border color",
      "default": "#9ca3af"
    },
    {
      "type": "header",
      "content": "Trust Indicators"
    },
    {
      "type": "color",
      "id": "trust_text_color",
      "label": "Trust text color",
      "default": "#6b7280"
    },
    {
      "type": "color",
      "id": "trust_icon_color",
      "label": "Trust icon color",
      "default": "#22c55e"
    },
    {
      "type": "header",
      "content": "Background Pattern"
    },
    {
      "type": "color",
      "id": "pattern_color",
      "label": "Pattern dot color",
      "default": "#3099d3"
    },
    {
      "type": "checkbox",
      "id": "show_background_pattern",
      "label": "Show background pattern",
      "default": false
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Trusted by Growing Shopify Brands"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Shared Sweeps brings together high-quality Shopify brands to fund one life-changing $100,000 sweepstakes — without upfront costs."
    },
    {
      "type": "header",
      "content": "Primary Button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Talk to Our Team"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "checkbox",
      "id": "button_opens_modal",
      "label": "Opens contact modal",
      "default": true,
      "info": "Enable if button should trigger a contact form modal"
    },
    {
      "type": "checkbox",
      "id": "show_button_icon",
      "label": "Show button arrow icon",
      "default": true
    },
    {
      "type": "header",
      "content": "Secondary Button"
    },
    {
      "type": "text",
      "id": "secondary_button_text",
      "label": "Secondary button text"
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "label": "Secondary button link"
    },
    {
      "type": "header",
      "content": "Additional Options"
    },
    {
      "type": "checkbox",
      "id": "show_trust_indicators",
      "label": "Show trust indicators",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "trust_indicator",
      "name": "Trust Indicator",
      "limit": 4,
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "check", "label": "Checkmark" },
            { "value": "shield", "label": "Shield" },
            { "value": "star", "label": "Star" }
          ],
          "default": "check"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "No upfront costs"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brands Hero",
      "blocks": []
    }
  ]
}
{% endschema %}