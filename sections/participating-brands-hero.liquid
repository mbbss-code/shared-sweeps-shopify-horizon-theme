{% comment %}
  Participating Brands Hero Section
  - Responsive design with Tailwind CSS
  - ADA Compliant with proper ARIA labels and semantic HTML
  - SEO Optimized with proper heading hierarchy
  - Fully customizable via Shopify schema
{% endcomment %}

<section 
  id="participating-brands-hero"
  class="tw-relative tw-overflow-hidden tw-border-b tw-border-gray-200/40 tw-bg-gradient-to-b tw-from-{{ section.settings.gradient_from }}/5 tw-to-white tw-py-20 md:tw-py-28"
  aria-labelledby="hero-heading"
  role="banner"
>
  {%- if section.settings.show_background_pattern -%}
    <div class="tw-absolute tw-inset-0 tw-opacity-5" aria-hidden="true">
      <svg class="tw-h-full tw-w-full" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="hero-pattern" x="0" y="0" width="40" height="40" patternUnits="userSpaceOnUse">
            <circle cx="20" cy="20" r="1.5" fill="currentColor" class="tw-text-{{ section.settings.primary_color }}" />
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#hero-pattern)" />
      </svg>
    </div>
  {%- endif -%}

  <div class="tw-container tw-mx-auto tw-px-4 tw-relative tw-z-10">
    <div class="tw-mx-auto tw-max-w-3xl tw-text-center">
      {%- if section.settings.badge_text != blank -%}
        <span class="tw-inline-block tw-mb-4 tw-px-4 tw-py-1.5 tw-text-sm tw-font-medium tw-text-{{ section.settings.primary_color }}-700 tw-bg-{{ section.settings.primary_color }}-100 tw-rounded-full">
          {{ section.settings.badge_text }}
        </span>
      {%- endif -%}

      <h1 
        id="hero-heading"
        class="tw-mb-6 tw-text-4xl tw-font-bold tw-tracking-tight tw-text-gray-900 md:tw-text-5xl lg:tw-text-6xl"
      >
        {{ section.settings.heading }}
      </h1>

      {%- if section.settings.subheading != blank -%}
        <p class="tw-mb-8 tw-text-lg tw-text-gray-600 md:tw-text-xl tw-leading-relaxed">
          {{ section.settings.subheading }}
        </p>
      {%- endif -%}

      {%- if section.settings.button_text != blank -%}
        <div class="tw-flex tw-flex-col sm:tw-flex-row tw-gap-4 tw-justify-center tw-items-center">
          {% if section.settings.button_opens_modal %}
            <button
              type="button"
              class="tw-inline-flex tw-items-center tw-justify-center tw-px-8 tw-py-3 tw-text-base tw-font-medium tw-text-white tw-bg-{{ section.settings.primary_color }}-600 tw-rounded-lg tw-shadow-lg hover:tw-bg-{{ section.settings.primary_color }}-700 focus:tw-outline-none focus:tw-ring-2 focus:tw-ring-offset-2 focus:tw-ring-{{ section.settings.primary_color }}-500 tw-transition-all tw-duration-200 hover:tw-shadow-xl hover:-tw-translate-y-0.5"
              data-contact-modal-trigger
              aria-haspopup="dialog"
            >
              {{ section.settings.button_text }}
              {%- if section.settings.show_button_icon -%}
                <svg class="tw-ml-2 -tw-mr-1 tw-w-5 tw-h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                </svg>
              {%- endif -%}
            </button>
          {% else %}
            <a 
              href="{{ section.settings.button_link }}"
              class="tw-inline-flex tw-items-center tw-justify-center tw-px-8 tw-py-3 tw-text-base tw-font-medium tw-text-white tw-bg-{{ section.settings.primary_color }}-600 tw-rounded-lg tw-shadow-lg hover:tw-bg-{{ section.settings.primary_color }}-700 focus:tw-outline-none focus:tw-ring-2 focus:tw-ring-offset-2 focus:tw-ring-{{ section.settings.primary_color }}-500 tw-transition-all tw-duration-200 hover:tw-shadow-xl hover:-tw-translate-y-0.5"
            >
              {{ section.settings.button_text }}
              {%- if section.settings.show_button_icon -%}
                <svg class="tw-ml-2 -tw-mr-1 tw-w-5 tw-h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                </svg>
              {%- endif -%}
            </a>
          {% endif %}

          {%- if section.settings.secondary_button_text != blank -%}
            <a 
              href="{{ section.settings.secondary_button_link }}"
              class="tw-inline-flex tw-items-center tw-justify-center tw-px-8 tw-py-3 tw-text-base tw-font-medium tw-text-gray-700 tw-bg-white tw-border tw-border-gray-300 tw-rounded-lg hover:tw-bg-gray-50 focus:tw-outline-none focus:tw-ring-2 focus:tw-ring-offset-2 focus:tw-ring-{{ section.settings.primary_color }}-500 tw-transition-all tw-duration-200"
            >
              {{ section.settings.secondary_button_text }}
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if section.settings.show_trust_indicators -%}
        <div class="tw-mt-10 tw-flex tw-flex-wrap tw-justify-center tw-gap-x-8 tw-gap-y-4 tw-text-sm tw-text-gray-500">
          {%- for block in section.blocks -%}
            {%- if block.type == 'trust_indicator' -%}
              <div class="tw-flex tw-items-center tw-gap-2" {{ block.shopify_attributes }}>
                {%- if block.settings.icon == 'check' -%}
                  <svg class="tw-w-5 tw-h-5 tw-text-green-500" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                {%- elsif block.settings.icon == 'shield' -%}
                  <svg class="tw-w-5 tw-h-5 tw-text-{{ section.settings.primary_color }}-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                  </svg>
                {%- elsif block.settings.icon == 'star' -%}
                  <svg class="tw-w-5 tw-h-5 tw-text-yellow-500" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                {%- endif -%}
                <span>{{ block.settings.text }}</span>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Brands Hero",
  "tag": "section",
  "class": "participating-brands-hero",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "aaad"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Trusted by Growing Shopify Brands"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Shared Sweeps brings together high-quality Shopify brands to fund one life-changing $100,000 sweepstakes — without upfront costs."
    },
    {
      "type": "header",
      "content": "Primary Button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Talk to Our Team"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "checkbox",
      "id": "button_opens_modal",
      "label": "Opens Contact Modal",
      "default": true,
      "info": "Enable if button should trigger a contact form modal"
    },
    {
      "type": "checkbox",
      "id": "show_button_icon",
      "label": "Show Button Arrow Icon",
      "default": true
    },
    {
      "type": "header",
      "content": "Secondary Button"
    },
    {
      "type": "text",
      "id": "secondary_button_text",
      "label": "Secondary Button Text"
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "label": "Secondary Button Link"
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "select",
      "id": "primary_color",
      "label": "Primary Color",
      "options": [
        { "value": "blue", "label": "Blue" },
        { "value": "indigo", "label": "Indigo" },
        { "value": "purple", "label": "Purple" },
        { "value": "pink", "label": "Pink" },
        { "value": "red", "label": "Red" },
        { "value": "orange", "label": "Orange" },
        { "value": "amber", "label": "Amber" },
        { "value": "emerald", "label": "Emerald" },
        { "value": "teal", "label": "Teal" },
        { "value": "cyan", "label": "Cyan" }
      ],
      "default": "indigo"
    },
    {
      "type": "select",
      "id": "gradient_from",
      "label": "Gradient Start Color",
      "options": [
        { "value": "blue", "label": "Blue" },
        { "value": "indigo", "label": "Indigo" },
        { "value": "purple", "label": "Purple" },
        { "value": "pink", "label": "Pink" },
        { "value": "emerald", "label": "Emerald" },
        { "value": "teal", "label": "Teal" }
      ],
      "default": "indigo"
    },
    {
      "type": "checkbox",
      "id": "show_background_pattern",
      "label": "Show Background Pattern",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_trust_indicators",
      "label": "Show Trust Indicators",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "trust_indicator",
      "name": "Trust Indicator",
      "limit": 4,
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "check", "label": "Checkmark" },
            { "value": "shield", "label": "Shield" },
            { "value": "star", "label": "Star" }
          ],
          "default": "check"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "No upfront costs"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brands Hero",
      "blocks": []
    }
  ]
}
{% endschema %}